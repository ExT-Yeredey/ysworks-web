---
import "@fontsource/inter/latin-400.css";
import "@fontsource/inter/latin-500.css";
import "@fontsource/inter/latin-600.css";
import "@fontsource/inter/latin-700.css";
import { ClientRouter } from "astro:transitions";
import "../styles/global.css";

interface Props {
	title?: string;
	description?: string;
	canonicalPath?: string;
	language?: "es" | "en";
	alternatePaths?: Partial<Record<"es" | "en" | "x-default", string>>;
	skipLinkLabel?: string;
	noindex?: boolean;
	structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
	title = "YSWORKS",
	description = "Ingeniería tecnológica para sistemas útiles, seguros y mantenibles.",
	canonicalPath = Astro.url.pathname,
	language = "es",
	alternatePaths,
	skipLinkLabel = language === "es" ? "Saltar al contenido" : "Skip to content",
	noindex = false,
	structuredData,
} = Astro.props;

const siteName = "YSWORKS";
const pageTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const canonicalUrl = new URL(
	canonicalPath,
	Astro.site ?? "https://www.ysworks.dev",
);
const ogLocale = language === "es" ? "es_ES" : "en_GB";
const alternateEntries = Object.entries(alternatePaths ?? {});
---

<!doctype html>
<html lang={language} data-theme="dark" data-theme-preference="dark" data-theme-source="system">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#09090b" />
		{noindex && <meta name="robots" content="noindex, nofollow" />}
		<link rel="canonical" href={canonicalUrl} />
		{
			alternateEntries.map(([hrefLang, path]) => (
				<link
					rel="alternate"
					hreflang={hrefLang}
					href={new URL(path, Astro.site ?? "https://www.ysworks.dev")}
				/>
			))
		}
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="manifest" href="/site.webmanifest" />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={siteName} />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalUrl} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:title" content={pageTitle} />
		<meta name="twitter:description" content={description} />
		{structuredData && (
			<script
				type="application/ld+json"
				is:inline
				set:html={JSON.stringify(structuredData)}
			/>
		)}
		<script is:inline>
			(() => {
				let preference = null;
				try {
					const saved = localStorage.getItem("ysworks-theme");
					if (saved === "light" || saved === "dark") preference = saved;
					else if (saved !== null) localStorage.removeItem("ysworks-theme");
				} catch {
					// The operating-system preference and dark fallback remain available.
				}
				const systemTheme = window.matchMedia?.("(prefers-color-scheme: light)").matches
					? "light"
					: "dark";
				const resolvedTheme = preference ?? systemTheme;
				document.documentElement.dataset.themePreference = resolvedTheme;
				document.documentElement.dataset.themeSource = preference ? "saved" : "system";
				document.documentElement.dataset.theme = resolvedTheme;
				if (!window.__ysworksThemeRouterReady) {
					window.__ysworksThemeRouterReady = true;
					document.addEventListener("astro:before-swap", (event) => {
						const current = document.documentElement.dataset;
						const incoming = event.newDocument.documentElement.dataset;
						incoming.theme = current.theme ?? "dark";
						incoming.themePreference = current.themePreference ?? incoming.theme;
						incoming.themeSource = current.themeSource ?? "system";
					});
				}
			})();
		</script>
		<ClientRouter />

		<title>{pageTitle}</title>
	</head>
	<body>
		<a class="skip-link" href="#main-content">{skipLinkLabel}</a>
		<div class="site-shell">
			<slot name="header" />
			<main id="main-content" class="site-main">
				<slot />
			</main>
			<slot name="footer" />
		</div>
	</body>
</html>

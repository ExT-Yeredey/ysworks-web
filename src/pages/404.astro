---
import Container from "../components/layout/Container.astro";
import Footer from "../components/layout/Footer.astro";
import Navbar from "../components/layout/Navbar.astro";
import Button from "../components/ui/Button.astro";
import { landingContent } from "../data/landing";
import BaseLayout from "../layouts/BaseLayout.astro";

const content = landingContent.es;
---

<BaseLayout
	title="Página no encontrada"
	description="La página solicitada no existe en la web pública de YSWORKS."
	canonicalPath="/404"
	noindex
>
	<Navbar
		slot="header"
		items={content.navigation.items}
		ctaLabel={content.navigation.cta}
		ctaHref="/contact"
		localeLink={{
			label: content.navigation.localeShort,
			href: "/en/",
			language: "en",
			ariaLabel: content.accessibility.localeLabel,
		}}
		lightThemeLabel={content.accessibility.lightTheme}
		darkThemeLabel={content.accessibility.darkTheme}
		systemThemeLabel={content.accessibility.systemTheme}
		themeMenuLabel={content.accessibility.themeMenu}
		lightThemeOption={content.accessibility.lightOption}
		darkThemeOption={content.accessibility.darkOption}
		systemThemeOption={content.accessibility.systemOption}
	/>
	<section class="not-found" aria-labelledby="not-found-title">
		<Container size="md">
			<div class="not-found__content">
				<p class="not-found__code">404 / ruta no encontrada</p>
				<h1 id="not-found-title">Esta página no forma parte del sistema.</h1>
				<p>
					La dirección puede haber cambiado o todavía no existir. Puedes volver al inicio o
					revisar los servicios disponibles.
				</p>
				<div class="not-found__actions">
					<Button href="/" variant="primary">Volver al inicio</Button>
					<Button href="/services" variant="secondary">Ver servicios</Button>
				</div>
			</div>
		</Container>
	</section>
	<Footer
		slot="footer"
		description={content.footer.description}
		items={content.navigation.items}
		legalItems={[{ label: content.footer.privacy, href: "/privacy" }]}
		statement={content.footer.statement}
	/>
</BaseLayout>

<style>
	.not-found { display: grid; place-items: center; min-height: 70vh; padding-block: var(--space-24); }
	.not-found__content { display: grid; justify-items: start; gap: var(--space-5); }
	.not-found__code { color: var(--color-accent-strong); font-family: var(--font-mono); font-size: var(--font-size-12); text-transform: uppercase; }
	h1 { max-width: 14ch; font-size: clamp(var(--font-size-40), 7vw, var(--font-size-64)); line-height: var(--line-height-tight); text-wrap: balance; }
	.not-found__content > p:not(.not-found__code) { max-width: 38rem; font-size: var(--font-size-18); }
	.not-found__actions { display: flex; flex-wrap: wrap; gap: var(--space-3); }
	@media (max-width: 499px) { .not-found__actions, .not-found__actions :global(.button) { width: 100%; } }
</style>

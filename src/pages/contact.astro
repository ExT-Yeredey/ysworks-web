---
import PageIntro from "../components/content/PageIntro.astro";
import Container from "../components/layout/Container.astro";
import Footer from "../components/layout/Footer.astro";
import Navbar from "../components/layout/Navbar.astro";
import Section from "../components/layout/Section.astro";
import Badge from "../components/ui/Badge.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const usefulContext = [
	"Qué problema quieres resolver o qué proceso necesita mejorar.",
	"Quién usa hoy el sistema y qué fricción encuentra.",
	"Qué resultado sería útil y qué restricciones debemos conocer.",
	"Si existe una fecha relevante, un sistema previo o una dependencia externa.",
];
---

<BaseLayout
	title="Contacto"
	description="Cuéntanos el problema tecnológico que quieres resolver. El canal público de contacto de YSWORKS se habilitará antes del lanzamiento."
	canonicalPath="/contact"
>
	<Navbar slot="header" />
	<PageIntro
		eyebrow="Contacto"
		title="Empecemos por entender el problema."
		description="Una buena conversación técnica no necesita una especificación perfecta. Necesita contexto suficiente para evaluar el encaje y definir el siguiente paso."
	/>

	<Section spacing="sm" aria-labelledby="channel-title">
		<Container size="lg">
			<div class="contact-grid">
				<section class="contact-status" data-reveal aria-labelledby="channel-title">
					<Badge>Estado del canal</Badge>
					<h2 id="channel-title">El canal público todavía no está habilitado.</h2>
					<p>
						Se publicará antes del lanzamiento cuando disponga de validación en servidor,
						protección contra abuso, minimización de datos y un aviso de privacidad adecuado.
					</p>
					<p class="contact-status__note">
						No hay un formulario simulado ni se envía información desde esta página.
					</p>
				</section>

				<section class="contact-brief" data-reveal aria-labelledby="brief-title">
					<p class="eyebrow">Para preparar la conversación</p>
					<h2 id="brief-title">Cuatro datos útiles.</h2>
					<ol>
						{
							usefulContext.map((item, index) => (
								<li>
									<span>{String(index + 1).padStart(2, "0")}</span>
									<p>{item}</p>
								</li>
							))
						}
					</ol>
				</section>
			</div>
		</Container>
	</Section>

	<Section spacing="md" aria-labelledby="future-form-title">
		<Container size="md">
			<div class="future-form" data-reveal>
				<div>
					<p class="eyebrow">Estructura prevista</p>
					<h2 id="future-form-title">Un contacto breve y seguro.</h2>
				</div>
				<p>
					El futuro formulario pedirá solo identidad de contacto, contexto del problema y
					consentimiento informado. No solicitará contraseñas, secretos, credenciales ni
					información sensible. La implementación se realizará en otra fase.
				</p>
			</div>
		</Container>
	</Section>

	<Footer slot="footer" />
</BaseLayout>

<style>
	.contact-grid { display: grid; gap: var(--space-6); }
	.contact-status,
	.contact-brief { display: grid; align-content: start; gap: var(--space-5); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-16); background: var(--color-surface); padding: var(--space-8); }
	.contact-status h2,
	.contact-brief h2,
	.future-form h2 { font-size: clamp(var(--font-size-24), 4vw, var(--font-size-32)); text-wrap: balance; }
	.contact-status__note { border-left: 1px solid var(--color-accent-border); color: var(--color-text-muted); font-size: var(--font-size-14); padding-left: var(--space-4); }
	.contact-brief ol { display: grid; margin: 0; padding: 0; list-style: none; }
	.contact-brief li { display: grid; grid-template-columns: 2rem 1fr; gap: var(--space-3); border-top: 1px solid var(--color-border-subtle); padding-block: var(--space-4); }
	.contact-brief li > span { color: var(--color-accent-strong); font-family: var(--font-mono); font-size: var(--font-size-12); }
	.future-form { display: grid; gap: var(--space-6); border-left: 1px solid var(--color-accent-border); padding-left: var(--space-6); }
	.future-form > div { display: grid; gap: var(--space-3); }

	@media (min-width: 850px) {
		.contact-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
		.future-form { grid-template-columns: minmax(0, 0.8fr) minmax(22rem, 1.2fr); gap: var(--space-12); }
	}
</style>

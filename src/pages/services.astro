---
import ContactCta from "../components/content/ContactCta.astro";
import PageIntro from "../components/content/PageIntro.astro";
import Container from "../components/layout/Container.astro";
import Footer from "../components/layout/Footer.astro";
import Navbar from "../components/layout/Navbar.astro";
import Section from "../components/layout/Section.astro";
import Badge from "../components/ui/Badge.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const serviceAreas = [
	{
		number: "01",
		title: "Automatización y soluciones inteligentes aplicadas",
		intro:
			"Convertimos tareas repetitivas y puntos de fricción en flujos controlados. La IA se incorpora solo cuando mejora un resultado concreto.",
		items: [
			"Análisis y rediseño de procesos",
			"Automatizaciones e integraciones supervisables",
			"Asistencia inteligente con revisión humana",
			"Validación, trazabilidad y documentación",
		],
		boundary:
			"No prometemos autonomía total ni automatizamos decisiones sensibles sin responsables y controles definidos.",
	},
	{
		number: "02",
		title: "Desarrollo digital",
		intro:
			"Diseñamos y construimos sitios, herramientas y plataformas web con una base rápida, accesible y preparada para mantenimiento.",
		items: [
			"Arquitectura de información y experiencia de usuario",
			"Sitios corporativos y plataformas web",
			"Interfaces para operaciones y productos",
			"Rendimiento, accesibilidad y SEO técnico",
		],
		boundary:
			"El alcance se define según el problema y el ciclo de vida esperado; evitamos añadir complejidad sin una necesidad verificable.",
	},
	{
		number: "03",
		title: "Infraestructura, sistemas y hardware profesional",
		intro:
			"Ayudamos a ordenar la base técnica que sostiene el trabajo diario, desde equipos y redes hasta servicios y continuidad operativa.",
		items: [
			"Diseño y revisión de entornos técnicos",
			"Selección e integración de hardware profesional",
			"Documentación y criterios de operación",
			"Mantenimiento y evolución planificada",
		],
		boundary:
			"Cada propuesta depende del contexto, los riesgos y la capacidad operativa. No publicamos ni exponemos arquitectura privada.",
	},
	{
		number: "04",
		title: "Ciberseguridad práctica",
		intro:
			"Reforzamos productos y operaciones con medidas proporcionadas: menos exposición, mejores configuraciones y límites comprensibles.",
		items: [
			"Revisión de superficie pública y configuraciones",
			"Controles de acceso y gestión de secretos",
			"Protección básica de formularios e integraciones",
			"Plan de mejoras y hardening documentado",
		],
		boundary:
			"Este servicio no se presenta como pentesting avanzado, respuesta forense ni operación ofensiva especializada.",
	},
	{
		number: "05",
		title: "Consultoría, soporte y evolución",
		intro:
			"Aportamos criterio técnico para entender un sistema existente, resolver bloqueos y decidir qué mejorar primero.",
		items: [
			"Diagnóstico técnico y priorización",
			"Acompañamiento de producto y tecnología",
			"Soporte sobre alcances acordados",
			"Documentación y transferencia de conocimiento",
		],
		boundary:
			"La colaboración se concreta con responsabilidades, disponibilidad y criterios de éxito explícitos.",
	},
];
---

<BaseLayout
	title="Servicios tecnológicos"
	description="Automatización, desarrollo web, soluciones inteligentes, infraestructura, ciberseguridad práctica y soporte técnico de YSWORKS."
	canonicalPath="/services"
>
	<Navbar slot="header" />
	<PageIntro
		eyebrow="Servicios"
		title="Ingeniería conectada de principio a fin."
		description="Combinamos producto, software, automatización, sistemas y seguridad para resolver problemas definidos sin convertir la tecnología en un fin en sí mismo."
	/>

	<Section spacing="sm" aria-labelledby="areas-title">
		<Container size="xl">
			<h2 id="areas-title" class="visually-hidden">Áreas de servicio</h2>
			<div class="areas">
				{
					serviceAreas.map((area) => (
						<article class="area" data-reveal>
							<div class="area__heading">
								<span>{area.number}</span>
								<h2>{area.title}</h2>
								<p>{area.intro}</p>
							</div>
							<div class="area__details">
								<div>
									<p class="eyebrow">Qué puede incluir</p>
									<ul>{area.items.map((item) => <li>{item}</li>)}</ul>
								</div>
								<div class="area__boundary">
									<Badge>Límite claro</Badge>
									<p>{area.boundary}</p>
								</div>
							</div>
						</article>
					))
				}
			</div>
		</Container>
	</Section>

	<ContactCta title="¿Qué necesita funcionar mejor en tu empresa?" />
	<Footer slot="footer" />
</BaseLayout>

<style>
	.areas { border-top: 1px solid var(--color-border-subtle); }
	.area { display: grid; gap: var(--space-8); border-bottom: 1px solid var(--color-border-subtle); padding-block: var(--space-12); }
	.area__heading { display: grid; align-content: start; gap: var(--space-4); }
	.area__heading > span { color: var(--color-accent-strong); font-family: var(--font-mono); font-size: var(--font-size-12); }
	.area h2 { max-width: 22ch; font-size: clamp(var(--font-size-24), 3vw, var(--font-size-32)); text-wrap: balance; }
	.area__heading > p { max-width: 43rem; font-size: var(--font-size-18); }
	.area__details { display: grid; gap: var(--space-6); }
	.area__details > div:first-child { display: grid; gap: var(--space-4); }
	.area ul { display: grid; gap: var(--space-3); margin: 0; padding: 0; list-style: none; }
	.area li { position: relative; color: var(--color-text-secondary); padding-left: var(--space-5); }
	.area li::before { position: absolute; top: 0.75em; left: 0; width: 0.35rem; height: 1px; background: var(--color-accent-strong); content: ""; }
	.area__boundary { display: grid; align-content: start; gap: var(--space-3); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-12); background: var(--color-surface); padding: var(--space-5); }

	@media (min-width: 900px) {
		.area { grid-template-columns: minmax(0, 1fr) minmax(25rem, 0.9fr); gap: var(--space-16); padding-block: var(--space-16); }
	}
</style>

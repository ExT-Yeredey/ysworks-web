---
import ContactCta from "../components/content/ContactCta.astro";
import PageIntro from "../components/content/PageIntro.astro";
import Container from "../components/layout/Container.astro";
import Footer from "../components/layout/Footer.astro";
import Navbar from "../components/layout/Navbar.astro";
import Section from "../components/layout/Section.astro";
import Badge from "../components/ui/Badge.astro";
import BaseLayout from "../layouts/BaseLayout.astro";

const principles = [
	[
		"01",
		"Claridad antes que espectáculo",
		"Explicamos el problema, los límites y las decisiones sin convertir la complejidad en marketing.",
	],
	[
		"02",
		"Mantenimiento antes que novedad",
		"Elegimos bases que puedan comprenderse, operarse y mejorar después de la primera entrega.",
	],
	[
		"03",
		"Seguridad desde el diseño",
		"Reducimos exposición y tratamos accesos, datos y dependencias como decisiones de producto.",
	],
	[
		"04",
		"Evidencia antes que promesas",
		"No inventamos resultados, credenciales ni capacidades. La confianza se construye con trabajo verificable.",
	],
];
---

<BaseLayout
	title="Sobre YSWORKS"
	description="Conoce el enfoque Quiet Engineering de YSWORKS: tecnología clara, segura, mantenible y conectada a resultados útiles."
	canonicalPath="/about"
>
	<Navbar slot="header" />
	<PageIntro
		eyebrow="Sobre YSWORKS"
		title="Complejidad invisible. Simplicidad visible."
		description="YSWORKS es una empresa de ingeniería tecnológica. Diseñamos sistemas útiles con calma, precisión y una mirada completa sobre producto, operación y seguridad."
	/>

	<Section spacing="sm" aria-labelledby="approach-title">
		<Container size="lg">
			<div class="approach" data-reveal>
				<div>
					<Badge>Quiet Engineering</Badge>
					<h2 id="approach-title">La calidad debe sentirse en el uso diario.</h2>
				</div>
				<div class="approach__copy">
					<p>
						Un buen sistema puede tener mucha ingeniería detrás y seguir siendo claro por
						fuera. Nuestro trabajo consiste en ordenar esa complejidad para que equipos y
						clientes puedan avanzar con confianza.
					</p>
					<p>
						La inteligencia artificial forma parte de nuestra capacidad técnica cuando existe
						un caso útil y controlable. No define por sí sola a la empresa ni sustituye el
						criterio, la responsabilidad o la revisión humana.
					</p>
				</div>
			</div>
		</Container>
	</Section>

	<Section spacing="md" aria-labelledby="principles-title">
		<Container size="xl">
			<div class="section-heading" data-reveal>
				<Badge>Principios</Badge>
				<h2 id="principles-title">Cómo tomamos decisiones.</h2>
			</div>
			<div class="principles">
				{
					principles.map(([number, title, description], index) => (
						<article data-reveal style={`--reveal-delay: ${(index % 2) * 60}ms`}>
							<span>{number}</span>
							<h3>{title}</h3>
							<p>{description}</p>
						</article>
					))
				}
			</div>
		</Container>
	</Section>

	<Section spacing="sm" aria-labelledby="fit-title">
		<Container size="lg">
			<div class="fit" data-reveal>
				<h2 id="fit-title">Una colaboración honesta empieza por el encaje.</h2>
				<p>
					Somos una buena opción cuando el problema necesita criterio técnico, límites
					claros y una solución que deberá mantenerse. Si una necesidad exige una capacidad
					especializada fuera del alcance acordado, lo diremos antes de avanzar.
				</p>
			</div>
		</Container>
	</Section>

	<ContactCta />
	<Footer slot="footer" />
</BaseLayout>

<style>
	.approach { display: grid; gap: var(--space-8); }
	.approach > div:first-child { display: grid; align-content: start; gap: var(--space-4); }
	.approach h2 { max-width: 20ch; font-size: clamp(var(--font-size-28), 4vw, var(--font-size-40)); text-wrap: balance; }
	.approach__copy { display: grid; gap: var(--space-5); }
	.approach__copy p { font-size: var(--font-size-18); }
	.principles { display: grid; border-top: 1px solid var(--color-border-subtle); }
	.principles article { display: grid; align-content: start; gap: var(--space-3); border-bottom: 1px solid var(--color-border-subtle); padding-block: var(--space-8); }
	.principles span { color: var(--color-accent-strong); font-family: var(--font-mono); font-size: var(--font-size-12); }
	.principles h3 { font-size: var(--font-size-18); }
	.fit { display: grid; gap: var(--space-5); border-left: 1px solid var(--color-accent-border); padding-left: var(--space-6); }
	.fit h2 { max-width: 23ch; font-size: clamp(var(--font-size-24), 4vw, var(--font-size-32)); text-wrap: balance; }
	.fit p { max-width: 48rem; font-size: var(--font-size-18); }

	@media (min-width: 800px) {
		.approach { grid-template-columns: minmax(0, 0.9fr) minmax(26rem, 1.1fr); gap: var(--space-16); }
		.principles { grid-template-columns: repeat(2, minmax(0, 1fr)); }
		.principles article { padding: var(--space-8); }
		.principles article:nth-child(odd) { border-right: 1px solid var(--color-border-subtle); }
	}
</style>

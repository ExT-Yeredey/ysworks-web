---
import ContactCta from "../components/content/ContactCta.astro";
import Container from "../components/layout/Container.astro";
import Footer from "../components/layout/Footer.astro";
import Navbar from "../components/layout/Navbar.astro";
import Section from "../components/layout/Section.astro";
import Badge from "../components/ui/Badge.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import { launchServices, processSteps, site } from "../data/site";
import BaseLayout from "../layouts/BaseLayout.astro";

const valuePoints = [
	{
		title: "Claridad operativa",
		description:
			"Sistemas que el equipo puede entender, usar y mantener con criterio.",
	},
	{
		title: "Menos trabajo manual",
		description:
			"Automatización selectiva para liberar tiempo sin perder control ni trazabilidad.",
	},
	{
		title: "Evolución segura",
		description:
			"Decisiones técnicas pensadas para crecer sin acumular exposición innecesaria.",
	},
];

const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "Organization",
		name: site.name,
		url: site.url,
		description: site.description,
	},
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: site.name,
		url: site.url,
		inLanguage: "es",
	},
];
---

<BaseLayout
	title="YSWORKS"
	description="Diseñamos, desarrollamos, automatizamos y protegemos soluciones tecnológicas para trabajar mejor, crecer con seguridad y reducir tareas manuales."
	canonicalPath="/"
	structuredData={structuredData}
>
	<Navbar slot="header" />

	<section class="hero" aria-labelledby="hero-title">
		<Container size="xl">
			<div class="hero__layout">
				<div class="hero__content">
					<Badge tone="accent" data-reveal>Ingeniería aplicada. Sin ruido.</Badge>
					<h1 id="hero-title" data-reveal style="--reveal-delay: 70ms">
						Tecnología que hace avanzar tu empresa.
					</h1>
					<p data-reveal style="--reveal-delay: 140ms">
						Diseñamos, desarrollamos, automatizamos y protegemos soluciones para trabajar
						mejor, crecer con seguridad y reducir tareas manuales.
					</p>
					<div class="hero__actions" data-reveal style="--reveal-delay: 210ms">
						<Button href="/contact" variant="primary">Cuéntanos tu proyecto</Button>
						<Button href="/services" variant="secondary">Explorar servicios</Button>
					</div>
				</div>

				<div class="system-map" aria-hidden="true" data-reveal style="--reveal-delay: 140ms">
					<div class="system-map__orbit system-map__orbit--one"></div>
					<div class="system-map__orbit system-map__orbit--two"></div>
					<span class="system-map__node system-map__node--center">YS</span>
					<span class="system-map__node system-map__node--a">01</span>
					<span class="system-map__node system-map__node--b">02</span>
					<span class="system-map__node system-map__node--c">03</span>
					<span class="system-map__label system-map__label--a">Diseñar</span>
					<span class="system-map__label system-map__label--b">Integrar</span>
					<span class="system-map__label system-map__label--c">Proteger</span>
				</div>
			</div>
		</Container>
	</section>

	<Section id="services" spacing="md" aria-labelledby="services-title">
		<Container size="xl">
			<div class="section-heading" data-reveal>
				<Badge>Servicios</Badge>
				<h2 id="services-title">Capacidad técnica conectada a problemas reales.</h2>
				<p>
					Desde una tarea manual hasta una plataforma completa: elegimos la intervención
					adecuada y dejamos una base que pueda evolucionar.
				</p>
			</div>
			<div class="service-grid">
				{
					launchServices.map((service, index) => (
						<a
							class="service-card"
							href="/services"
							data-reveal
							style={`--reveal-delay: ${(index % 3) * 60}ms`}
						>
							<span class="service-card__number">{service.number}</span>
							<h3>{service.title}</h3>
							<p>{service.description}</p>
							<span class="service-card__link">Ver enfoque <span aria-hidden="true">→</span></span>
						</a>
					))
				}
			</div>
		</Container>
	</Section>

	<Section spacing="md" aria-labelledby="value-title">
		<Container size="xl">
			<div class="value-panel" data-reveal>
				<div class="value-panel__intro">
					<p class="eyebrow">Valor sostenible</p>
					<h2 id="value-title">La tecnología debe simplificar el trabajo, no añadir otra capa de ruido.</h2>
				</div>
				<div class="value-panel__list">
					{
						valuePoints.map((point, index) => (
							<div class="value-point">
								<span>{String(index + 1).padStart(2, "0")}</span>
								<div>
									<h3>{point.title}</h3>
									<p>{point.description}</p>
								</div>
							</div>
						))
					}
				</div>
			</div>
		</Container>
	</Section>

	<Section id="process" spacing="md" aria-labelledby="process-title">
		<Container size="xl">
			<div class="section-heading" data-reveal>
				<Badge>Proceso</Badge>
				<h2 id="process-title">Un camino claro desde el problema hasta un sistema útil.</h2>
			</div>
			<ol class="process-list">
				{
					processSteps.map((step, index) => (
						<li data-reveal style={`--reveal-delay: ${index * 60}ms`}>
							<div class="process-step">
								<span>{step.number}</span>
								<h3>{step.title}</h3>
								<p>{step.description}</p>
							</div>
						</li>
					))
				}
			</ol>
		</Container>
	</Section>

	<Section spacing="md" aria-labelledby="trust-title">
		<Container size="lg">
			<div class="trust" data-reveal>
				<div>
					<Badge>Confianza</Badge>
					<h2 id="trust-title">Ingeniería responsable, también en lo que decidimos no hacer.</h2>
				</div>
				<div class="trust__copy">
					<p>
						Trabajamos con límites explícitos, comunicación directa y decisiones que priorizan
						seguridad, rendimiento y mantenimiento.
					</p>
					<ul>
						<li>Alcance y riesgos claros antes de construir.</li>
						<li>Datos y accesos tratados con minimización.</li>
						<li>Sin métricas, testimonios o capacidades inventadas.</li>
					</ul>
				</div>
			</div>
		</Container>
	</Section>

	<Section spacing="md" aria-labelledby="capabilities-title">
		<Container size="xl">
			<div class="capabilities" data-reveal>
				<div class="section-heading">
					<Badge>Capacidades complementarias</Badge>
					<h2 id="capabilities-title">Una visión conectada de producto, operación y tecnología.</h2>
				</div>
				<div class="capabilities__grid">
					<Card>
						<p class="eyebrow">Integración</p>
						<h3>Sistemas que colaboran</h3>
						<p>Conectamos herramientas y datos mediante interfaces controladas y documentadas.</p>
					</Card>
					<Card>
						<p class="eyebrow">Diagnóstico</p>
						<h3>Decidir antes de invertir</h3>
						<p>Analizamos una base existente y priorizamos mejoras por impacto y riesgo.</p>
					</Card>
					<Card>
						<p class="eyebrow">Continuidad</p>
						<h3>Documentar para evolucionar</h3>
						<p>Dejamos decisiones y límites comprensibles para reducir dependencia y fricción.</p>
					</Card>
				</div>
			</div>
		</Container>
	</Section>

	<ContactCta />
	<Footer slot="footer" />
</BaseLayout>

<style>
	.hero {
		padding-block: var(--space-24);
	}

	.hero__layout {
		display: grid;
		align-items: center;
		gap: var(--space-12);
		min-height: min(44rem, calc(100svh - 4.25rem));
	}

	.hero__content {
		display: grid;
		gap: var(--space-6);
		max-width: 52rem;
	}

	.hero h1 {
		max-width: 14ch;
		font-size: clamp(var(--font-size-40), 8vw, var(--font-size-72));
		line-height: 1.02;
		letter-spacing: -0.055em;
		text-wrap: balance;
	}

	.hero__content > p {
		max-width: 42rem;
		font-size: clamp(var(--font-size-18), 2.4vw, var(--font-size-22));
		text-wrap: pretty;
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
	}

	.system-map {
		position: relative;
		width: min(100%, 30rem);
		aspect-ratio: 1;
		justify-self: center;
		border: 1px solid var(--color-border-subtle);
		border-radius: 50%;
		background: radial-gradient(circle, var(--color-accent-soft), transparent 62%);
	}

	.system-map::before,
	.system-map::after {
		position: absolute;
		background: var(--color-border-subtle);
		content: "";
	}

	.system-map::before { inset: 50% 0 auto; height: 1px; }
	.system-map::after { inset: 0 auto 0 50%; width: 1px; }

	.system-map__orbit {
		position: absolute;
		border: 1px solid var(--color-border-subtle);
		border-radius: 50%;
	}

	.system-map__orbit--one { inset: 18%; }
	.system-map__orbit--two { inset: 34%; }

	.system-map__node {
		position: absolute;
		z-index: 1;
		display: grid;
		place-items: center;
		width: 2.5rem;
		height: 2.5rem;
		border: 1px solid var(--color-accent-border);
		border-radius: 50%;
		background: var(--color-bg-elevated);
		font-family: var(--font-mono);
		font-size: var(--font-size-12);
	}

	.system-map__node--center { top: 50%; left: 50%; transform: translate(-50%, -50%); background: var(--color-accent); }
	.system-map__node--a { top: 12%; left: 46%; }
	.system-map__node--b { right: 9%; bottom: 25%; }
	.system-map__node--c { bottom: 8%; left: 24%; }

	.system-map__label {
		position: absolute;
		color: var(--color-text-muted);
		font-family: var(--font-mono);
		font-size: var(--font-size-12);
	}

	.system-map__label--a { top: 24%; left: 12%; }
	.system-map__label--b { top: 31%; right: 8%; }
	.system-map__label--c { bottom: 26%; left: 8%; }

	.service-grid {
		display: grid;
		border-top: 1px solid var(--color-border-subtle);
	}

	.service-card {
		display: grid;
		gap: var(--space-4);
		border-bottom: 1px solid var(--color-border-subtle);
		padding: var(--space-6) 0;
		transition: background-color var(--motion-duration-base) var(--motion-ease-standard);
	}

	.service-card:hover { background: var(--color-accent-soft); }
	.service-card__number { color: var(--color-text-muted); font-family: var(--font-mono); font-size: var(--font-size-12); }
	.service-card h3 { font-size: var(--font-size-18); }
	.service-card__link { color: var(--color-text-muted); font-size: var(--font-size-14); font-weight: var(--font-weight-medium); }

	.value-panel {
		display: grid;
		gap: var(--space-10);
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-16);
		background: var(--color-surface);
		padding: var(--space-8);
	}

	.value-panel__intro { display: grid; gap: var(--space-4); }
	.value-panel__intro h2 { max-width: 20ch; font-size: clamp(var(--font-size-28), 4vw, var(--font-size-48)); text-wrap: balance; }
	.value-panel__list { display: grid; }
	.value-point { display: grid; grid-template-columns: 2rem 1fr; gap: var(--space-3); border-top: 1px solid var(--color-border-subtle); padding-block: var(--space-5); }
	.value-point > span { color: var(--color-text-muted); font-family: var(--font-mono); font-size: var(--font-size-12); }
	.value-point div { display: grid; gap: var(--space-2); }
	.value-point h3 { font-size: var(--font-size-18); }

	.process-list {
		display: grid;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.process-step {
		display: grid;
		gap: var(--space-3);
		min-height: 100%;
		border-top: 1px solid var(--color-border-subtle);
		padding: var(--space-6) var(--space-4) var(--space-6) 0;
	}

	.process-step > span { color: var(--color-accent-strong); font-family: var(--font-mono); font-size: var(--font-size-12); }
	.process-step h3 { font-size: var(--font-size-18); }

	.trust { display: grid; gap: var(--space-8); }
	.trust > div:first-child { display: grid; gap: var(--space-4); }
	.trust h2 { max-width: 24ch; font-size: clamp(var(--font-size-28), 4vw, var(--font-size-40)); text-wrap: balance; }
	.trust__copy { display: grid; gap: var(--space-6); }
	.trust__copy > p { font-size: var(--font-size-18); }
	.trust ul { display: grid; gap: var(--space-3); margin: 0; padding: 0; list-style: none; }
	.trust li { border-left: 1px solid var(--color-accent-border); color: var(--color-text-secondary); padding-left: var(--space-4); }

	.capabilities { border-top: 1px solid var(--color-border-subtle); padding-top: var(--space-12); }
	.capabilities__grid { display: grid; gap: var(--space-4); }
	.capabilities__grid :global(.card) { display: grid; gap: var(--space-3); }
	.capabilities__grid h3 { font-size: var(--font-size-18); }

	#services,
	#process { scroll-margin-top: 6rem; }

	@media (min-width: 700px) {
		.service-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
		.service-card { padding: var(--space-8); }
		.service-card:nth-child(odd) { border-right: 1px solid var(--color-border-subtle); }
		.process-list { grid-template-columns: repeat(2, minmax(0, 1fr)); }
		.process-step { border-right: 1px solid var(--color-border-subtle); padding: var(--space-6); }
		.capabilities__grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
	}

	@media (min-width: 1024px) {
		.hero__layout { grid-template-columns: minmax(0, 1.3fr) minmax(20rem, 0.7fr); }
		.service-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
		.service-card:nth-child(odd) { border-right: 0; }
		.service-card:not(:nth-child(3n)) { border-right: 1px solid var(--color-border-subtle); }
		.value-panel { grid-template-columns: minmax(0, 1.1fr) minmax(22rem, 0.9fr); padding: var(--space-12); }
		.process-list { grid-template-columns: repeat(4, minmax(0, 1fr)); }
		.trust { grid-template-columns: minmax(0, 1fr) minmax(24rem, 0.8fr); }
	}

	@media (max-width: 499px) {
		.hero__actions :global(.button) { width: 100%; }
		.system-map { width: 18rem; max-width: 92vw; }
	}
</style>

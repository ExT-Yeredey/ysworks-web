---
import type { HTMLAttributes } from "astro/types";

export type IconName =
	| "arrow-right"
	| "automation"
	| "check"
	| "cloud"
	| "code"
	| "infrastructure"
	| "intelligence"
	| "mail"
	| "security"
	| "support"
	| "web"
	| "workflow";

interface Props extends Omit<HTMLAttributes<"svg">, "name"> {
	name: IconName;
	label?: string;
	size?: 16 | 20 | 24 | 32;
	tone?: "inherit" | "accent" | "muted";
}

const paths: Record<IconName, string[]> = {
	"arrow-right": ["M5 12h14", "m14 7 5 5-5 5"],
	automation: [
		"M8 3H5a2 2 0 0 0-2 2v3",
		"M16 3h3a2 2 0 0 1 2 2v3",
		"M8 21H5a2 2 0 0 1-2-2v-3",
		"M16 21h3a2 2 0 0 0 2-2v-3",
		"m12 7-4 5h4l-1 5 5-6h-4l0-4Z",
	],
	check: ["m5 12 4 4L19 6"],
	cloud: [
		"M17.5 19H6a4 4 0 0 1-.6-7.96A7 7 0 0 1 19 9.5 4.75 4.75 0 0 1 17.5 19Z",
	],
	code: ["m8 9-3 3 3 3", "m16 9 3 3-3 3", "m14 5-4 14"],
	infrastructure: [
		"M4 4h16v6H4z",
		"M4 14h16v6H4z",
		"M8 7h.01",
		"M8 17h.01",
		"M12 7h4",
		"M12 17h4",
	],
	intelligence: [
		"M12 3a6 6 0 0 0-3.7 10.72A3 3 0 0 1 10 16.45V18h4v-1.55a3 3 0 0 1 1.7-2.73A6 6 0 0 0 12 3Z",
		"M10 21h4",
		"M9.5 11.5h5",
	],
	mail: ["M4 5h16v14H4z", "m4 7 8 6 8-6"],
	security: [
		"M12 3 5 6v5c0 4.4 2.9 6.8 7 8 4.1-1.2 7-3.6 7-8V6l-7-3Z",
		"m9 12 2 2 4-4",
	],
	support: [
		"M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Z",
		"M6.4 6.4 9 9",
		"m15 9 2.6-2.6",
		"m6.4 17.6 2.6-2.6",
		"m15 15 2.6 2.6",
	],
	web: [
		"M4 5h16v14H4z",
		"M4 9h16",
		"M7 7h.01",
		"M10 7h.01",
		"M8 13h3v3H8z",
		"M14 13h3",
		"M14 16h3",
	],
	workflow: [
		"M4 4h6v6H4z",
		"M14 14h6v6h-6z",
		"M7 10v2a2 2 0 0 0 2 2h5",
		"m12 11 3 3-3 3",
	],
};

const {
	name,
	label,
	size = 24,
	tone = "inherit",
	class: className,
	...attrs
} = Astro.props;
const classes = ["icon", `icon--${tone}`, className].filter(Boolean).join(" ");
---

<svg
	class={classes}
	width={size}
	height={size}
	viewBox="0 0 24 24"
	fill="none"
	stroke="currentColor"
	stroke-width="1.75"
	stroke-linecap="round"
	stroke-linejoin="round"
	role={label ? "img" : undefined}
	aria-hidden={label ? undefined : "true"}
	{...attrs}
>
	{label && <title>{label}</title>}
	{paths[name].map((path) => <path d={path}></path>)}
</svg>

<style>
	.icon {
		display: inline-block;
		flex: none;
	}

	.icon--accent {
		color: var(--color-accent-strong);
	}

	.icon--muted {
		color: var(--color-text-muted);
	}
</style>

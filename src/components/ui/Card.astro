---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"article"> {
	as?: "article" | "div" | "section";
	tone?: "default" | "elevated" | "transparent";
	padding?: "sm" | "md" | "lg";
	interactive?: boolean;
	fill?: boolean;
}

const {
	as = "article",
	tone = "default",
	padding = "md",
	interactive = false,
	fill = false,
	class: className,
	...attrs
} = Astro.props;
const Element = as;
const classes = [
	"card",
	`card--${tone}`,
	`card--padding-${padding}`,
	interactive && "card--interactive",
	fill && "card--fill",
	className,
]
	.filter(Boolean)
	.join(" ");
---

<Element class={classes} {...attrs}>
	<slot />
</Element>

<style>
	.card {
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--surface-radius);
		background:
			linear-gradient(180deg, color-mix(in srgb, var(--color-surface-elevated), transparent 66%), transparent 42%),
			var(--color-surface);
		box-shadow: var(--shadow-surface);
	}

	.card--elevated {
		background: var(--color-surface-elevated);
		box-shadow: var(--shadow-raised);
	}

	.card--transparent {
		background: transparent;
		box-shadow: none;
	}

	.card--padding-sm {
		padding: var(--surface-padding-sm);
	}

	.card--padding-md {
		padding: var(--surface-padding-md);
	}

	.card--padding-lg {
		padding: var(--surface-padding-lg);
	}

	.card--fill {
		height: 100%;
	}

	.card--interactive {
		transition:
			border-color var(--motion-duration-fast) var(--motion-ease-standard),
			background-color var(--motion-duration-fast) var(--motion-ease-standard),
			transform var(--motion-duration-fast) var(--motion-ease-standard);
	}

	.card--interactive:hover,
	.card--interactive:focus-within {
		border-color: var(--color-border-strong);
		background: var(--color-surface-elevated);
		transform: translateY(var(--motion-lift-surface));
	}
</style>

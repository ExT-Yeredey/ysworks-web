---
import CtaCard from "../cards/CtaCard.astro";
import ServiceCard from "../cards/ServiceCard.astro";
import Faq from "../content/Faq.astro";
import Process from "../content/Process.astro";
import Icon from "../icons/Icon.astro";
import CopyButton from "../interactive/CopyButton.astro";
import Container from "../layout/Container.astro";
import Footer from "../layout/Footer.astro";
import Navbar from "../layout/Navbar.astro";
import LandingMotion from "../motion/LandingMotion.astro";
import Section from "../layout/Section.astro";
import HeroTitle from "../typography/HeroTitle.astro";
import MonoEyebrow from "../typography/MonoEyebrow.astro";
import Paragraph from "../typography/Paragraph.astro";
import SectionTitle from "../typography/SectionTitle.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";
import { landingContent, type LandingLocale } from "../../data/landing";
import BaseLayout from "../../layouts/BaseLayout.astro";

interface Props {
	locale: LandingLocale;
}

const { locale } = Astro.props;
const content = landingContent[locale];
const alternateLanguage = locale === "es" ? "en" : "es";
const contactHref = locale === "es" ? "/contact" : "/en/contact/";
const servicesHref = locale === "es" ? "/services" : "/en/services/";
const processHref = locale === "es" ? "/process" : "/en/process/";
const aboutHref = locale === "es" ? "/about" : "/en/about/";
const continuation =
	locale === "es"
		? {
				process: "Conocer el proceso completo",
				technology: "Ver capacidades y servicios",
				about: "Conocer cómo trabaja YSWORKS",
				contact: "Preparar una conversación",
			}
		: {
				process: "Explore the complete process",
				technology: "View capabilities and services",
				about: "Learn how YSWORKS works",
				contact: "Prepare a conversation",
			};
const localeLink = {
	label: content.navigation.localeShort,
	href: content.alternatePath,
	language: alternateLanguage as LandingLocale,
	ariaLabel: content.accessibility.localeLabel,
};
const alternatePaths = {
	es: "/",
	en: "/en/",
	"x-default": "/",
};
const structuredData = [
	{
		"@context": "https://schema.org",
		"@type": "Organization",
		name: "YSWORKS",
		url: "https://www.ysworks.dev",
		email: "contact@ysworks.dev",
		description: content.seo.description,
	},
	{
		"@context": "https://schema.org",
		"@type": "WebSite",
		name: "YSWORKS",
		url: new URL(content.canonicalPath, "https://www.ysworks.dev").toString(),
		inLanguage: content.language,
	},
];
---

<BaseLayout
	title="YSWORKS"
	description={content.seo.description}
	canonicalPath={content.canonicalPath}
	language={content.language}
	alternatePaths={alternatePaths}
	skipLinkLabel={content.accessibility.skipLink}
	structuredData={structuredData}
>
	<Navbar
		slot="header"
		items={content.navigation.items}
		brandHref={content.canonicalPath}
		currentPath={content.canonicalPath}
		navigationLabel={content.accessibility.navigation}
		menuLabel={content.accessibility.menu}
		closeLabel={content.accessibility.close}
		homeLabel={content.accessibility.home}
		localeLink={localeLink}
		lightThemeLabel={content.accessibility.lightTheme}
		darkThemeLabel={content.accessibility.darkTheme}
		themeMenuLabel={content.accessibility.themeMenu}
		lightThemeOption={content.accessibility.lightOption}
		darkThemeOption={content.accessibility.darkOption}
	/>

	<div data-landing>
	<section class="landing-hero" aria-labelledby="hero-title">
		<Container size="xl">
			<div class="landing-hero__layout">
				<div class="landing-hero__content" data-hero-sequence>
					<Badge tone="accent">{content.hero.eyebrow}</Badge>
					<HeroTitle id="hero-title">
						{content.hero.title}
					</HeroTitle>
					<Paragraph size="lg" measure="wide">
						{content.hero.description}
					</Paragraph>
					<div class="landing-hero__actions">
						<Button href={contactHref} variant="primary">{content.hero.primaryCta}</Button>
						<Button href={servicesHref} variant="secondary">{content.hero.secondaryCta}</Button>
					</div>
				</div>

				<figure class="signature" aria-labelledby="signature-caption" data-signature>
					<span class="signature__wordmark" aria-label="YSWORKS">
						<span>YSWORKS</span>
						<svg viewBox="0 0 144 48" aria-hidden="true" data-signature-mark><rect x="1" y="1" width="142" height="46" rx="8"></rect></svg>
					</span>
					<div class="signature__flow">
						<svg class="signature__rail" viewBox="0 0 2 300" preserveAspectRatio="none" aria-hidden="true">
							<path class="signature__rail-base" d="M1 0V300"></path>
							<path class="signature__rail-progress" d="M1 0V300" data-signature-progress></path>
							<path class="signature__rail-pulse" d="M1 0V300" data-signature-pulse></path>
						</svg>
						{
							content.hero.diagram.map((node, index) => (
								<button type="button" class:list={["signature__node", { "signature__node--accent": index === 1 }]} data-signature-node aria-pressed="false">
									<Icon name={node.icon} size={20} />
									<span>{node.title}</span>
									<small>{node.description}</small>
								</button>
							))
						}
					</div>
					<figcaption id="signature-caption">{content.hero.diagramCaption}</figcaption>
				</figure>
			</div>
		</Container>
	</section>

	<Section id="services" spacing="lg" aria-labelledby="services-title">
		<Container size="xl">
			<header class="landing-heading">
				<MonoEyebrow>{content.services.eyebrow}</MonoEyebrow>
				<SectionTitle id="services-title" size="lg">{content.services.title}</SectionTitle>
				<Paragraph size="lg">{content.services.description}</Paragraph>
			</header>
			<div class="services-overview" data-services-grid>
				{
					content.services.items.slice(0, 3).map((service, index) => (
						<div
							class="services-overview__item"
							data-service-item
							data-service-number={service.number}
							style={`--service-detail: ${28 + index * 9}%`}
						>
							<ServiceCard
								title={service.title}
								description={service.description}
								eyebrow={service.number}
							>
								<Icon slot="icon" name={service.icon} size={20} />
							</ServiceCard>
						</div>
					))
				}
			</div>
			<div class="services-overview__footer">
				<Button href={servicesHref} variant="text">{content.services.exploreLabel} →</Button>
			</div>
		</Container>
	</Section>

	<div class="landing-section" id="process">
		<Container size="xl">
			<div>
				<Process
					id="delivery-process"
					eyebrow={content.process.eyebrow}
					title={content.process.title}
					description={content.process.description}
					steps={content.process.steps}
				/>
			</div>
			<div class="section-continuation">
				<Button href={processHref} variant="text">{continuation.process} →</Button>
			</div>
		</Container>
	</div>

	<Section id="technology" spacing="lg" tone="muted" aria-labelledby="technology-title" data-technology>
		<Container size="xl">
			<header class="landing-heading">
				<MonoEyebrow>{content.technology.eyebrow}</MonoEyebrow>
				<SectionTitle id="technology-title" size="lg">{content.technology.title}</SectionTitle>
				<Paragraph size="lg">{content.technology.description}</Paragraph>
			</header>
			<div class="technology-map">
				{
					content.technology.items.map((item, index) => (
						<article class="technology-map__node" tabindex="0">
							<span class="technology-map__divider" data-technology-divider aria-hidden="true"></span>
							<div data-technology-label><Icon name={item.icon} size={20} /><span>{String(index + 1).padStart(2, "0")}</span></div>
							<div class="technology-map__body" data-technology-body>
								<small>{item.category}</small>
								<h3>{item.name}</h3>
								<p>{item.description}</p>
							</div>
						</article>
					))
				}
			</div>
			<div class="section-continuation">
				<Button href={servicesHref} variant="text">{continuation.technology} →</Button>
			</div>
		</Container>
	</Section>

	<div class="landing-section trust-section" data-human-criteria>
		<Container size="lg">
			<div class="trust-section__layout">
				<div class="trust-section__copy" data-human-heading>
					<MonoEyebrow>{content.trust.eyebrow}</MonoEyebrow>
					<SectionTitle size="lg">{content.trust.title}</SectionTitle>
					<Paragraph size="lg">{content.trust.body}</Paragraph>
				</div>
				<ul>
					{content.trust.points.map((point, index) => <li data-human-row><span>{String(index + 1).padStart(2, "0")}</span>{point}</li>)}
				</ul>
				<div class="section-continuation">
					<Button href={aboutHref} variant="text">{continuation.about} →</Button>
				</div>
			</div>
		</Container>
	</div>

	<div class="landing-section" id="faq">
		<Container size="xl">
			<div>
				<Faq
					id="common-questions"
					eyebrow={content.faq.eyebrow}
					title={content.faq.title}
					description={content.faq.description}
					items={content.faq.items.slice(0, 4)}
				/>
				<div class="section-continuation">
					<Button href={contactHref} variant="text">{continuation.contact} →</Button>
				</div>
			</div>
		</Container>
	</div>

	<Section id="contact" spacing="lg" aria-label={content.contact.eyebrow} data-contact-section>
		<Container size="lg">
			<MonoEyebrow class="contact-eyebrow">{content.contact.eyebrow}</MonoEyebrow>
			<CtaCard
				title={content.contact.title}
				description={content.contact.description}
			>
				<div slot="actions" class="contact-actions">
					<Button
						href="mailto:contact@ysworks.dev"
						variant="primary"
					>
						<Icon name="mail" size={16} />
						{content.contact.emailLabel}
					</Button>
					<CopyButton
						value="contact@ysworks.dev"
						label={content.contact.copyLabel}
						copiedLabel={content.contact.copiedLabel}
						errorLabel={content.contact.copyErrorLabel}
					/>
				</div>
			</CtaCard>
		</Container>
	</Section>
	<LandingMotion />
	</div>

	<Footer
		slot="footer"
		description={content.footer.description}
		items={content.navigation.items}
		legalItems={[{ label: content.footer.privacy, href: locale === "es" ? "/privacy" : "/en/privacy/" }]}
		navigationLabel={content.accessibility.footerNavigation}
		statement={content.footer.statement}
		localeLink={localeLink}
	/>
</BaseLayout>

<style>
	.landing-hero {
		position: relative;
		isolation: isolate;
		border-bottom: 1px solid var(--color-border-subtle);
		padding-block: var(--space-16) var(--space-24);
		background:
			linear-gradient(var(--color-grid) 1px, transparent 1px),
			linear-gradient(90deg, var(--color-grid) 1px, transparent 1px);
		background-size: 3rem 3rem;
	}

	.landing-hero::after {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(ellipse at 78% 42%, var(--color-accent-soft), transparent 34rem),
			linear-gradient(180deg, transparent 72%, var(--color-bg) 100%);
		content: "";
		pointer-events: none;
	}

	.landing-hero__layout {
		display: grid;
		align-items: center;
		gap: var(--space-12);
		min-height: min(43rem, calc(100svh - 4.25rem));
	}

	.landing-hero__content,
	.landing-heading {
		display: grid;
		gap: var(--space-5);
	}

	.services-overview {
		display: grid;
		gap: 1px;
		overflow: hidden;
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-12);
		background: var(--color-border-subtle);
	}

	.services-overview__item {
		position: relative;
		min-width: 0;
		background: var(--color-bg);
	}

	.services-overview__item::after {
		position: absolute;
		right: var(--space-6);
		bottom: 0;
		width: var(--service-detail);
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--color-accent));
		content: "";
		opacity: 0.38;
		pointer-events: none;
	}

	.services-overview__item :global(.card.service-card) {
		min-height: 100%;
		border: 0;
		border-radius: 0;
		box-shadow: none;
		padding: var(--space-8);
	}

	.services-overview__footer {
		display: flex;
		justify-content: flex-end;
		padding-top: var(--space-5);
	}

	.section-continuation {
		display: flex;
		justify-content: flex-end;
		padding-top: var(--space-5);
	}

	.landing-hero__content {
		max-width: 52rem;
		padding-block: var(--space-4);
	}

	.landing-hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
		padding-top: var(--space-2);
	}

	.signature {
		position: relative;
		display: grid;
		gap: var(--space-5);
		overflow: hidden;
		min-width: 0;
		margin: 0;
		border: 1px solid var(--color-border-strong);
		border-radius: var(--radius-16);
		background:
			linear-gradient(155deg, var(--color-accent-soft), transparent 38%),
			var(--color-bg-translucent);
		box-shadow:
			inset 0 1px 0 rgb(255 255 255 / 0.035),
			0 1.5rem 4.5rem rgb(0 0 0 / 0.16);
		padding: var(--space-6);
	}

	.signature::after {
		position: absolute;
		top: 0;
		right: 12%;
		left: 12%;
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--color-accent-border), transparent);
		content: "";
	}

	.signature__wordmark {
		position: relative;
		display: inline-grid;
		place-items: center;
		width: 9rem;
		height: 3rem;
		border: 1px solid var(--color-accent-border);
		border-radius: var(--radius-8);
		background: var(--color-accent-soft);
		color: var(--color-text-primary);
		font-family: var(--font-mono);
		font-size: var(--font-size-12);
		font-weight: var(--font-weight-semibold);
		letter-spacing: 0.12em;
	}

	.signature__wordmark svg {
		position: absolute;
		inset: -1px;
		width: calc(100% + 2px);
		height: calc(100% + 2px);
		color: var(--color-accent);
		pointer-events: none;
	}

	.signature__wordmark rect {
		fill: none;
		stroke: currentColor;
		stroke-width: 1.5;
		vector-effect: non-scaling-stroke;
	}

	.signature__flow {
		position: relative;
		display: grid;
		gap: var(--space-4);
		padding-left: var(--space-8);
	}

	.signature__rail {
		position: absolute;
		top: calc(var(--space-5) * -1);
		bottom: var(--space-5);
		left: var(--space-6);
		width: 2px;
		height: calc(100% + var(--space-5));
		overflow: visible;
	}

	.signature__rail path {
		fill: none;
		stroke-width: 1.5;
		vector-effect: non-scaling-stroke;
	}

	.signature__rail-base {
		stroke: var(--color-accent);
		opacity: 0.4;
	}

	.signature__rail-progress {
		stroke: var(--color-accent);
		opacity: 0;
	}

	.signature__rail-pulse {
		stroke: var(--color-accent-hover);
		stroke-linecap: round;
		opacity: 0.72;
	}

	.signature__node {
		position: relative;
		display: grid;
		grid-template-columns: auto 1fr;
		gap: var(--space-1) var(--space-3);
		min-width: 0;
		min-height: 4.5rem;
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-8);
		background: var(--color-surface);
		color: inherit;
		cursor: default;
		font: inherit;
		padding: var(--space-4);
		text-align: left;
		transition:
			border-color var(--motion-duration-base) var(--motion-ease-in-out-quad),
			background-color var(--motion-duration-base) var(--motion-ease-in-out-quad),
			color var(--motion-duration-fast) var(--motion-ease-in-out-quad);
	}

	.signature__node::before {
		position: absolute;
		top: 50%;
		left: calc(var(--space-8) * -1);
		width: var(--space-8);
		height: 1px;
		background: var(--color-accent);
		content: "";
		opacity: 0.4;
		transition: opacity var(--motion-duration-fast) var(--motion-ease-in-out-quad);
	}

	.signature__node :global(svg) {
		grid-row: 1 / 3;
		color: var(--color-accent-strong);
	}

	.signature__node span {
		color: var(--color-text-primary);
		font-weight: var(--font-weight-medium);
	}

	.signature__node small,
	.signature figcaption {
		color: var(--color-text-muted);
		font-size: var(--font-size-12);
	}

	.signature__node--accent {
		border-color: var(--color-accent-border);
		background: var(--color-accent-soft);
	}

	.signature__node[data-active],
	.signature__node[data-proximity],
	.signature__node[data-tapped] {
		border-color: var(--color-accent);
		background: color-mix(in srgb, var(--color-accent-soft), var(--color-surface) 35%);
	}

	.signature__node[data-proximity] :global(svg),
	.signature__node[data-tapped] :global(svg),
	.signature__node[data-proximity] small,
	.signature__node[data-tapped] small {
		color: var(--color-accent-strong);
	}

	.signature__node[data-active]::before,
	.signature__node[data-proximity]::before,
	.signature__node[data-tapped]::before {
		opacity: 0.8;
	}

	.landing-heading {
		max-width: 48rem;
		margin-bottom: var(--space-12);
	}

	.landing-section {
		scroll-margin-top: 5rem;
		padding-block: var(--space-24);
	}

	.technology-map {
		display: grid;
		grid-auto-rows: minmax(0, 1fr);
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-12);
		background: var(--color-bg-elevated);
		box-shadow: inset 0 1px 0 rgb(255 255 255 / 0.025);
	}

	.technology-map__node {
		position: relative;
		display: grid;
		align-content: start;
		gap: var(--space-3);
		min-width: 0;
		min-height: 13rem;
		padding: var(--space-6);
	}

	.technology-map__divider {
		position: absolute;
		top: 0;
		right: 0;
		left: 0;
		height: 1px;
		transform-origin: left;
		background: var(--color-border-subtle);
	}

	.technology-map__node:first-child .technology-map__divider {
		display: none;
	}

	.technology-map__body {
		display: grid;
		align-content: start;
		gap: var(--space-3);
	}

	.technology-map__node + .technology-map__node {
		border-top: 1px solid var(--color-border-subtle);
	}

	.technology-map__node > [data-technology-label] {
		display: flex;
		align-items: center;
		justify-content: space-between;
		color: var(--color-accent-strong);
	}

	.technology-map__node:hover > [data-technology-label] > span,
	.technology-map__node:focus-visible > [data-technology-label] > span {
		color: var(--color-accent-strong);
	}

	.technology-map__node small,
	.technology-map__node > [data-technology-label] span {
		color: var(--color-text-muted);
		font-family: var(--font-mono);
		font-size: var(--font-size-12);
		text-transform: uppercase;
	}

	.technology-map__node h3 {
		font-size: var(--font-size-18);
		text-wrap: balance;
	}

	.technology-map__node p {
		max-width: 32rem;
	}

	.trust-section {
		border-block: 1px solid var(--color-border-subtle);
		background: linear-gradient(90deg, transparent, var(--color-accent-soft), transparent);
	}

	.trust-section__layout,
	.trust-section__copy {
		display: grid;
		gap: var(--space-5);
	}

	.trust-section__layout > ul {
		display: grid;
		gap: 0;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.trust-section__layout li {
		--human-line: 1;
		position: relative;
		display: grid;
		grid-template-columns: 2rem 1fr;
		gap: var(--space-3);
		color: var(--color-text-secondary);
		padding-block: var(--space-4);
	}

	.trust-section__layout li::before {
		position: absolute;
		top: 0;
		right: 0;
		left: 0;
		height: 1px;
		transform: scaleX(var(--human-line));
		transform-origin: left;
		background: var(--color-border-subtle);
		content: "";
	}

	.trust-section__layout li span {
		color: var(--color-accent-strong);
		font-family: var(--font-mono);
		font-size: var(--font-size-12);
	}

	#services,
	#technology,
	#contact {
		scroll-margin-top: 5rem;
	}

	.contact-eyebrow {
		margin-bottom: var(--space-4);
	}

	.contact-actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-3);
	}

	@media (min-width: 48rem) {
		.services-overview {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.technology-map {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.technology-map__node:nth-child(2) {
			border-top: 0;
		}

		.technology-map__node:nth-child(even) {
			border-left: 1px solid var(--color-border-subtle);
		}

		.technology-map__node:nth-child(even) .technology-map__divider {
			top: 0;
			bottom: 0;
			left: 0;
			width: 1px;
			height: auto;
			transform-origin: top;
		}
	}

	@media (min-width: 64rem) {
		.landing-hero {
			padding-block: var(--space-24);
		}

		.landing-hero__layout {
			grid-template-columns: minmax(0, 1.05fr) minmax(25rem, 0.95fr);
			gap: var(--space-12);
		}

		.landing-heading {
			grid-template-columns: minmax(0, 1.1fr) minmax(20rem, 0.9fr);
			column-gap: var(--space-16);
			max-width: none;
		}


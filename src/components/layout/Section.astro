---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"section"> {
	spacing?: "sm" | "md" | "lg";
	tone?: "default" | "muted" | "accent";
	contained?: boolean;
	containerSize?: "sm" | "md" | "lg" | "xl";
}

const {
	spacing = "md",
	tone = "default",
	contained = false,
	containerSize = "lg",
	class: className,
	...attrs
} = Astro.props;
const classes = [
	"section",
	`section--${spacing}`,
	`section--${tone}`,
	className,
]
	.filter(Boolean)
	.join(" ");
---

<section class={classes} {...attrs}>
	{
		contained ? (
			<div class={`section__container section__container--${containerSize}`}>
				<slot />
			</div>
		) : (
			<slot />
		)
	}
</section>

<style>
	.section {
		padding-block: var(--space-16);
	}

	.section--sm {
		padding-block: var(--space-12);
	}

	.section--md {
		padding-block: var(--space-16);
	}

	.section--lg {
		padding-block: var(--space-24);
	}

	.section--muted {
		background: var(--color-bg-elevated);
	}

	.section--accent {
		background: var(--color-accent-soft);
	}

	.section__container {
		width: min(100% - (var(--space-5) * 2), var(--container-xl));
		margin-inline: auto;
	}

	.section__container--sm {
		max-width: var(--container-sm);
	}

	.section__container--md {
		max-width: var(--container-md);
	}

	.section__container--lg {
		max-width: var(--container-lg);
	}

	.section__container--xl {
		max-width: var(--container-xl);
	}

	@media (min-width: 768px) {
		.section {
			padding-block: var(--space-24);
		}

		.section--sm {
			padding-block: var(--space-16);
		}

		.section--lg {
			padding-block: calc(var(--space-24) + var(--space-4));
		}

		.section__container {
			width: min(100% - (var(--space-8) * 2), var(--container-xl));
		}
	}
</style>

---
import ThemeToggle from "../interactive/ThemeToggle.astro";
import Button from "../ui/Button.astro";
import Container from "./Container.astro";

export interface NavItem {
	label: string;
	href: string;
}

interface Props {
	items?: NavItem[];
	brandLabel?: string;
	brandHref?: string;
	currentPath?: string;
	ctaLabel?: string;
	ctaHref?: string;
	navigationLabel?: string;
	menuLabel?: string;
	closeLabel?: string;
	homeLabel?: string;
	menuId?: string;
	localeLink?: NavItem & { language: "es" | "en"; ariaLabel: string };
	lightThemeLabel?: string;
	darkThemeLabel?: string;
	systemThemeLabel?: string;
}

const {
	items = [],
	brandLabel = "YSWORKS",
	brandHref = "/",
	currentPath = Astro.url.pathname,
	ctaLabel = "Hablemos de tu proyecto",
	ctaHref = "/contact",
	navigationLabel = "Navegación principal",
	menuLabel = "Menú",
	closeLabel = "Cerrar",
	homeLabel = `${brandLabel}, inicio`,
	menuId = "mobile-navigation",
	localeLink,
	lightThemeLabel = "Usar tema claro",
	darkThemeLabel = "Usar tema oscuro",
	systemThemeLabel = "Usar tema del sistema",
} = Astro.props;

const isActive = (href: string) => {
	if (href.includes("#")) return false;
	const path = href.split("#")[0] || "/";
	return path === "/" ? currentPath === "/" : currentPath.startsWith(path);
};
---

<ys-navbar class="navbar">
	<Container size="xl">
		<nav class="navbar__inner" aria-label={navigationLabel}>
			<a class="navbar__brand" href={brandHref} aria-label={homeLabel}>
				<span class="navbar__name">{brandLabel}</span>
			</a>

			<div class="navbar__desktop">
				<ul class="navbar__links">
					{
						items.map((item) => (
							<li>
								<a
									class="navbar__link"
									href={item.href}
									aria-current={isActive(item.href) ? "page" : undefined}
								>
									{item.label}
								</a>
							</li>
						))
					}
				</ul>
				<div class="navbar__actions">
					{
						localeLink && (
							<a
								class="navbar__locale"
								href={localeLink.href}
								lang={localeLink.language}
								hreflang={localeLink.language}
								aria-label={localeLink.ariaLabel}
							>
								{localeLink.label}
							</a>
						)
					}
					<ThemeToggle
						lightLabel={lightThemeLabel}
						darkLabel={darkThemeLabel}
						systemLabel={systemThemeLabel}
					/>
					<slot name="actions">
						<Button href={ctaHref} variant="primary" size="sm">{ctaLabel}</Button>
					</slot>
				</div>
			</div>

			<div class="navbar__compact">
				<span class="navbar__tablet-cta">
					<Button href={ctaHref} variant="primary" size="sm">{ctaLabel}</Button>
				</span>
				<button
					class="navbar__toggle"
					type="button"
					aria-expanded="false"
					aria-controls={menuId}
					data-menu-toggle
				>
					<span>{menuLabel}</span>
					<span class="navbar__toggle-icon" aria-hidden="true"><i></i><i></i></span>
				</button>
			</div>
		</nav>
	</Container>

	<div class="mobile-nav" id={menuId} data-mobile-menu hidden>
		<button
			class="mobile-nav__backdrop"
			type="button"
			aria-label={closeLabel}
			data-menu-close
		></button>
		<div class="mobile-nav__panel" role="dialog" aria-modal="true" aria-label={navigationLabel}>
			<div class="mobile-nav__top">
				<span class="eyebrow">{navigationLabel}</span>
				<div class="mobile-nav__controls">
					<ThemeToggle
						lightLabel={lightThemeLabel}
						darkLabel={darkThemeLabel}
						systemLabel={systemThemeLabel}
					/>
					<button class="mobile-nav__close" type="button" data-menu-close>
						{closeLabel}
					</button>
				</div>
			</div>
			<ul class="mobile-nav__links">
				{
					items.map((item) => (
						<li>
							<a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
								<span>{item.label}</span>
								<span aria-hidden="true">↗</span>
							</a>
						</li>
					))
				}
			</ul>
			{
				localeLink && (
					<a
						class="mobile-nav__locale"
						href={localeLink.href}
						lang={localeLink.language}
						hreflang={localeLink.language}
						aria-label={localeLink.ariaLabel}
					>
						{localeLink.label}
					</a>
				)
			}
			<Button href={ctaHref} variant="primary">{ctaLabel}</Button>
		</div>
	</div>
</ys-navbar>

<script>
	import { animate, stagger } from "animejs";

	class YsNavbar extends HTMLElement {
		connectedCallback() {
			const toggle = this.querySelector<HTMLButtonElement>("[data-menu-toggle]");
			const menu = this.querySelector<HTMLElement>("[data-mobile-menu]");
			const panel = menu?.querySelector<HTMLElement>(".mobile-nav__panel");
			const backdrop = menu?.querySelector<HTMLElement>(".mobile-nav__backdrop");
			if (!toggle || !menu || !panel || !backdrop) return;

			document.documentElement.dataset.menuReady = "true";
			let previousFocus: HTMLElement | null = null;
			let closing = false;
			const reducedMotion = () =>
				window.matchMedia("(prefers-reduced-motion: reduce)").matches;
			const focusable = () =>
				Array.from(
					panel.querySelectorAll<HTMLElement>(
						'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
					),
				);

			const finishClose = (restoreFocus = true) => {
				menu.hidden = true;
				closing = false;
				panel.removeAttribute("style");
				backdrop.removeAttribute("style");
				for (const item of menu.querySelectorAll<HTMLElement>(".mobile-nav__links li")) {
					item.removeAttribute("style");
				}
				if (restoreFocus) previousFocus?.focus();
			};

			const closeMenu = (immediate = false) => {
				if (menu.hidden || closing) return;
				closing = true;
				toggle.setAttribute("aria-expanded", "false");
				document.body.removeAttribute("data-scroll-lock");
				if (immediate || reducedMotion()) {
					finishClose(!immediate);
					return;
				}
				animate(backdrop, { opacity: 0, duration: 150, ease: "in(2)" });
				animate(panel, {
					x: "100%",
					opacity: 0.98,
					duration: 210,
					ease: "in(3)",
					onComplete: () => finishClose(),
				});
			};

			const openMenu = () => {
				previousFocus = document.activeElement as HTMLElement;
				menu.hidden = false;
				toggle.setAttribute("aria-expanded", "true");
				document.body.dataset.scrollLock = "true";
				const items = menu.querySelectorAll<HTMLElement>(".mobile-nav__links li");
				if (!reducedMotion()) {
					animate(backdrop, { opacity: [0, 1], duration: 180, ease: "out(2)" });
					animate(panel, { x: ["100%", 0], duration: 240, ease: "out(4)" });
					animate(items, {
						opacity: [0, 1],
						x: [12, 0],
						delay: stagger(32, { start: 45 }),
						duration: 210,
						ease: "out(3)",
					});
				}
				window.requestAnimationFrame(() => focusable()[0]?.focus());
			};

			toggle.addEventListener("click", () => (menu.hidden ? openMenu() : closeMenu()));
			for (const control of menu.querySelectorAll<HTMLElement>("[data-menu-close]")) {
				control.addEventListener("click", () => closeMenu());
			}
			for (const link of menu.querySelectorAll<HTMLAnchorElement>("a")) {
				link.addEventListener("click", () => closeMenu());
			}

			document.addEventListener("keydown", (event) => {
				if (menu.hidden) return;
				if (event.key === "Escape") {
					event.preventDefault();
					closeMenu();
					return;
				}
				if (event.key !== "Tab") return;
				const items = focusable();
				const first = items[0];
				const last = items.at(-1);
				if (event.shiftKey && document.activeElement === first) {
					event.preventDefault();
					last?.focus();
				} else if (!event.shiftKey && document.activeElement === last) {
					event.preventDefault();
					first?.focus();
				}
			});

			window.addEventListener("resize", () => {
				if (window.innerWidth >= 860 && !menu.hidden) closeMenu(true);
			});
		}
	}

	if (!customElements.get("ys-navbar")) customElements.define("ys-navbar", YsNavbar);
</script>

<style>
	.navbar {
		position: sticky;
		top: 0;
		z-index: 50;
		display: block;
		border-bottom: 1px solid var(--color-border-subtle);
		background: var(--color-bg-translucent);
		backdrop-filter: blur(18px);
	}

	.navbar__inner,
	.navbar__desktop,
	.navbar__links,
	.navbar__actions,
	.navbar__brand,
	.mobile-nav__top,
	.mobile-nav__controls,
	.mobile-nav__links a {
		display: flex;
		align-items: center;
	}

	.navbar__inner {
		justify-content: space-between;
		gap: var(--space-4);
		min-height: 4.25rem;
	}

	.navbar__brand {
		flex: none;
		border-radius: var(--radius-6);
		font-weight: var(--font-weight-semibold);
		line-height: var(--line-height-ui);
	}

	.navbar__name {
		font-size: var(--font-size-16);
		letter-spacing: 0.08em;
	}

	.navbar__desktop {
		justify-content: flex-end;
		gap: var(--space-3);
	}

	.navbar__links {
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: var(--space-1);
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.navbar__link {
		display: inline-flex;
		align-items: center;
		min-height: 2rem;
		border-radius: var(--radius-6);
		color: var(--color-text-muted);
		font-size: var(--font-size-14);
		font-weight: var(--font-weight-medium);
		padding-inline: var(--space-3);
		transition:
			background-color var(--motion-duration-fast) var(--motion-ease-standard),
			color var(--motion-duration-fast) var(--motion-ease-standard);
	}

	.navbar__link:hover,
	.navbar__link[aria-current="page"] {
		background: var(--color-surface);
		color: var(--color-text-primary);
	}

	.navbar__locale,
	.mobile-nav__locale {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.5rem;
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-6);
		color: var(--color-text-secondary);
		font-family: var(--font-mono);
		font-size: var(--font-size-12);
		font-weight: var(--font-weight-medium);
		padding-inline: var(--space-3);
	}

	.navbar__locale:hover,
	.mobile-nav__locale:hover {
		border-color: var(--color-border-strong);
		color: var(--color-text-primary);
	}

	.navbar__toggle {
		display: none;
		gap: var(--space-3);
		min-height: 2.5rem;
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-6);
		background: var(--color-surface);
		color: var(--color-text-primary);
		font-size: var(--font-size-14);
		padding-inline: var(--space-3);
	}

	.navbar__compact {
		display: none;
		align-items: center;
		gap: var(--space-2);
	}

	.navbar__toggle-icon {
		display: grid;
		gap: 0.25rem;
		width: 1rem;
	}

	.navbar__toggle-icon i {
		display: block;
		height: 1px;
		background: currentColor;
	}

	.mobile-nav[hidden] {
		display: none;
	}

	.mobile-nav {
		position: fixed;
		inset: 0;
		z-index: 60;
		display: grid;
		grid-template-columns: minmax(2rem, 1fr) minmax(17rem, 26rem);
	}

	.mobile-nav__backdrop {
		border: 0;
		background: rgb(0 0 0 / 0.62);
		backdrop-filter: blur(4px);
	}

	.mobile-nav__panel {
		display: flex;
		flex-direction: column;
		gap: var(--space-8);
		min-height: 100dvh;
		border-left: 1px solid var(--color-border-subtle);
		background: var(--color-bg-elevated);
		padding: var(--space-5);
	}

	.mobile-nav__top,
	.mobile-nav__links a {
		justify-content: space-between;
	}

	.mobile-nav__controls {
		gap: var(--space-2);
	}

	.mobile-nav__locale {
		width: fit-content;
	}

	.mobile-nav__close {
		min-height: 2.5rem;
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-6);
		background: var(--color-surface);
		color: var(--color-text-primary);
		font-size: var(--font-size-14);
		padding-inline: var(--space-3);
	}

	.mobile-nav__links {
		display: grid;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.mobile-nav__links a {
		min-height: 3.5rem;
		border-bottom: 1px solid var(--color-border-subtle);
		font-size: var(--font-size-18);
	}

	.mobile-nav__links a[aria-current="page"] {
		color: var(--color-accent-strong);
	}

	@media (max-width: 859px) {
		html[data-menu-ready="true"] .navbar__desktop {
			display: none;
		}

		html[data-menu-ready="true"] .navbar__compact,
		html[data-menu-ready="true"] .navbar__toggle {
			display: flex;
		}

		.navbar__desktop {
			flex-wrap: wrap;
		}

		.navbar__desktop :global(.button) {
			display: none;
		}
	}

	@media (max-width: 639px) {
		.navbar__tablet-cta {
			display: none;
		}
	}
</style>

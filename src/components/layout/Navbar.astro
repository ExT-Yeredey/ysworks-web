---
import ThemeToggle from "../interactive/ThemeToggle.astro";
import Container from "./Container.astro";

export interface NavItem {
	label: string;
	href: string;
}

interface Props {
	items?: NavItem[];
	brandLabel?: string;
	brandHref?: string;
	currentPath?: string;
	navigationLabel?: string;
	menuLabel?: string;
	closeLabel?: string;
	homeLabel?: string;
	menuId?: string;
	localeLink?: NavItem & { language: "es" | "en"; ariaLabel: string };
	lightThemeLabel?: string;
	darkThemeLabel?: string;
	themeMenuLabel?: string;
	lightThemeOption?: string;
	darkThemeOption?: string;
	clientArea?: NavItem;
}

const {
	items = [],
	brandLabel = "YSWORKS",
	brandHref = "/",
	currentPath = Astro.url.pathname,
	navigationLabel = "Navegación principal",
	menuLabel = "Menú",
	closeLabel = "Cerrar",
	homeLabel = `${brandLabel}, inicio`,
	menuId = "mobile-navigation",
	localeLink,
	lightThemeLabel = "Usar tema claro",
	darkThemeLabel = "Usar tema oscuro",
	themeMenuLabel = "Tema",
	lightThemeOption = "Claro",
	darkThemeOption = "Oscuro",
	clientArea,
} = Astro.props;

const isActive = (href: string) => {
	if (href.includes("#")) return false;
	const path = href.split("#")[0] || "/";
	return path === "/" || path === "/en/"
		? currentPath === path
		: currentPath.startsWith(path);
};
---

<ys-navbar class="navbar">
	<Container size="xl">
		<nav class="navbar__inner" aria-label={navigationLabel}>
			<a class="navbar__brand" href={brandHref} aria-label={homeLabel}>
				<span class="navbar__name">{brandLabel}</span>
			</a>

			<div class="navbar__desktop">
				<div class="navbar__links-wrap">
				<ul class="navbar__links">
					{
						items.map((item) => (
							<li>
								<a
									class="navbar__link"
									href={item.href}
									aria-current={isActive(item.href) ? "page" : undefined}
								>
									{item.label}
								</a>
							</li>
						))
					}
				</ul>
				<span class="navbar__indicator" aria-hidden="true" data-nav-indicator></span>
				</div>
				<div class="navbar__actions">
					{
						localeLink && (
							<a
								class="navbar__locale"
								href={localeLink.href}
								lang={localeLink.language}
								hreflang={localeLink.language}
								aria-label={localeLink.ariaLabel}
							>
								{localeLink.label}
							</a>
						)
					}
					<ThemeToggle
						menuId="desktop-theme-menu"
						menuLabel={themeMenuLabel}
						lightLabel={lightThemeLabel}
						darkLabel={darkThemeLabel}
						lightOptionLabel={lightThemeOption}
						darkOptionLabel={darkThemeOption}
					/>
					{clientArea && <a class="navbar__client-area" href={clientArea.href}>{clientArea.label}</a>}
				</div>
			</div>

			<div class="navbar__compact">
				<button
					class="navbar__toggle"
					type="button"
					aria-expanded="false"
					aria-controls={menuId}
					data-menu-toggle
				>
					<span>{menuLabel}</span>
					<span class="navbar__toggle-icon" aria-hidden="true"><i></i><i></i></span>
				</button>
			</div>
		</nav>
	</Container>

	<div class="mobile-nav" id={menuId} data-mobile-menu hidden>
		<button
			class="mobile-nav__backdrop"
			type="button"
			aria-label={closeLabel}
			data-menu-close
		></button>
		<div class="mobile-nav__panel" role="dialog" aria-modal="true" aria-label={navigationLabel}>
			<div class="mobile-nav__top">
				<span class="eyebrow">{navigationLabel}</span>
				<div class="mobile-nav__controls">
					<ThemeToggle
						menuId="mobile-theme-menu"
						menuLabel={themeMenuLabel}
						mobile
						lightLabel={lightThemeLabel}
						darkLabel={darkThemeLabel}
						lightOptionLabel={lightThemeOption}
						darkOptionLabel={darkThemeOption}
					/>
					<button class="mobile-nav__close" type="button" data-menu-close>
						{closeLabel}
					</button>
				</div>
			</div>
			<ul class="mobile-nav__links">
				{
					items.map((item) => (
						<li>
							<a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
								<span>{item.label}</span>
								<span aria-hidden="true">↗</span>
							</a>
						</li>
					))
				}
			</ul>
			{
				localeLink && (
					<a
						class="mobile-nav__locale"
						href={localeLink.href}
						lang={localeLink.language}
						hreflang={localeLink.language}
						aria-label={localeLink.ariaLabel}
					>
						{localeLink.label}
					</a>
				)
			}
			{clientArea && <a class="mobile-nav__client-area" href={clientArea.href}>{clientArea.label}</a>}
		</div>
	</div>
</ys-navbar>

<script>
	import {
		motion,
		prefersReducedMotion,
		registerOpenLayer,
		scheduleFrame,
		unregisterOpenLayer,
	} from "../../lib/motion";

	class YsNavbar extends HTMLElement {
		private controller?: AbortController;

		connectedCallback() {
			this.controller?.abort();
			this.controller = new AbortController();
			const { signal } = this.controller;
			const toggle = this.querySelector<HTMLButtonElement>("[data-menu-toggle]");
			const menu = this.querySelector<HTMLElement>("[data-mobile-menu]");
			const panel = menu?.querySelector<HTMLElement>(".mobile-nav__panel");
			const backdrop = menu?.querySelector<HTMLElement>(".mobile-nav__backdrop");
			const desktopLinks = Array.from(this.querySelectorAll<HTMLAnchorElement>(".navbar__link"));
			const indicator = this.querySelector<HTMLElement>("[data-nav-indicator]");
			if (!toggle || !menu || !panel || !backdrop) return;

			document.documentElement.dataset.menuReady = "true";
			let previousFocus: HTMLElement | null = null;
			let closing = false;
			let menuAnimations: Animation[] = [];
			const reducedMotion = prefersReducedMotion;
			const cancelMenuAnimations = () => {
				for (const animation of menuAnimations) animation.cancel();
				menuAnimations = [];
			};
			const focusable = () =>
				Array.from(
					panel.querySelectorAll<HTMLElement>(
						'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
					),
				);

			const finishClose = (restoreFocus = true) => {
				cancelMenuAnimations();
				menu.hidden = true;
				closing = false;
				panel.removeAttribute("style");
				backdrop.removeAttribute("style");
				for (const item of menu.querySelectorAll<HTMLElement>(".mobile-nav__links li")) {
					item.removeAttribute("style");
				}
				if (restoreFocus) previousFocus?.focus();
				unregisterOpenLayer(menu);
			};

			const closeMenu = (immediate = false) => {
				if (menu.hidden || closing) return;
				closing = true;
				for (const selector of menu.querySelectorAll<HTMLElement>("ys-theme-selector")) {
					selector.dispatchEvent(new CustomEvent("ysworks-layer-close"));
				}
				toggle.setAttribute("aria-expanded", "false");
				document.body.removeAttribute("data-scroll-lock");
				if (immediate || reducedMotion()) {
					finishClose(!immediate);
					return;
				}
				cancelMenuAnimations();
				const backdropAnimation = backdrop.animate([{ opacity: 1 }, { opacity: 0 }], {
					duration: motion.duration.fast,
					easing: motion.waapiEase.inQuad,
				});
				const panelAnimation = panel.animate(
					[
						{ transform: "translateX(0)", opacity: 1 },
						{ transform: "translateX(100%)", opacity: 0.98 },
					],
					{ duration: motion.duration.base, easing: motion.waapiEase.inQuad },
				);
				menuAnimations = [backdropAnimation, panelAnimation];
				panelAnimation.addEventListener("finish", () => finishClose(), { once: true });
			};

			const openMenu = () => {
				previousFocus = document.activeElement as HTMLElement;
				menu.hidden = false;
				toggle.setAttribute("aria-expanded", "true");
				document.body.dataset.scrollLock = "true";
				registerOpenLayer(menu, () => closeMenu());
				const items = menu.querySelectorAll<HTMLElement>(".mobile-nav__links li");
				if (!reducedMotion()) {
					cancelMenuAnimations();
					menuAnimations = [
						backdrop.animate([{ opacity: 0 }, { opacity: 1 }], {
							duration: motion.duration.base,
							easing: motion.waapiEase.outQuart,
						}),
						panel.animate(
							[{ transform: "translateX(100%)" }, { transform: "translateX(0)" }],
							{ duration: motion.duration.base, easing: motion.waapiEase.outQuart },
						),
						...Array.from(items).map((item, index) =>
							item.animate(
								[
									{ opacity: 0, transform: `translateX(${motion.travel.sm}px)` },
									{ opacity: 1, transform: "translateX(0)" },
								],
								{
									delay: motion.stagger.mobile * (index + 1),
									duration: motion.duration.base,
									easing: motion.waapiEase.outQuart,
								},
							),
						),
					];
				}
				window.requestAnimationFrame(() => focusable()[0]?.focus());
			};

			toggle.addEventListener("click", () => (menu.hidden ? openMenu() : closeMenu()), { signal });
			for (const control of menu.querySelectorAll<HTMLElement>("[data-menu-close]")) {
				control.addEventListener("click", () => closeMenu(), { signal });
			}
			for (const link of menu.querySelectorAll<HTMLAnchorElement>("a")) {
				link.addEventListener("click", () => closeMenu(), { signal });
			}

			document.addEventListener("keydown", (event) => {
				if (menu.hidden) return;
				if (event.key !== "Tab") return;
				const items = focusable();
				const first = items[0];
				const last = items.at(-1);
				if (event.shiftKey && document.activeElement === first) {
					event.preventDefault();
					last?.focus();
				} else if (!event.shiftKey && document.activeElement === last) {
					event.preventDefault();
					first?.focus();
				}
			}, { signal });

			const updateNavigation = () => {
				this.toggleAttribute("data-condensed", window.scrollY >= motion.choreography.navigationCondense);
				if (window.innerWidth >= motion.breakpoint.navigationDesktop && !menu.hidden) closeMenu(true);
			};
			const scheduleNavigationUpdate = scheduleFrame(updateNavigation);
			window.addEventListener("scroll", scheduleNavigationUpdate, { passive: true, signal });
			window.addEventListener("resize", scheduleNavigationUpdate, { signal });
			updateNavigation();

			if (indicator) {
				const indicatorTrack = indicator.parentElement;
				const active = () => desktopLinks.find((link) => link.getAttribute("aria-current") === "page");
				const moveIndicator = (link?: HTMLAnchorElement, draw = false) => {
					if (!link) {
						indicator.style.opacity = "0";
						return;
					}
					if (!indicatorTrack) return;
					const linkRect = link.getBoundingClientRect();
					const trackRect = indicatorTrack.getBoundingClientRect();
					indicator.style.opacity = "1";
					indicator.style.setProperty("--indicator-x", `${linkRect.left - trackRect.left}px`);
					indicator.style.setProperty("--indicator-width", `${linkRect.width}px`);
					if (draw && !reducedMotion()) {
						indicator.animate([{ scale: "0 1" }, { scale: "1 1" }], {
							duration: motion.duration.base,
							easing: motion.waapiEase.outQuart,
						});
					}
				};
				for (const link of desktopLinks) {
					link.addEventListener("pointerenter", () => moveIndicator(link), { signal });
					link.addEventListener("focus", () => moveIndicator(link), { signal });
					link.addEventListener("pointerleave", () => moveIndicator(active()), { signal });
					link.addEventListener("blur", () => moveIndicator(active()), { signal });
				}
				window.addEventListener("resize", () => moveIndicator(active()), { signal });
				moveIndicator(active(), true);
			}
		}

		disconnectedCallback() {
			this.controller?.abort();
			const menu = this.querySelector<HTMLElement>("[data-mobile-menu]");
			if (menu) unregisterOpenLayer(menu);
		}
	}

	if (!customElements.get("ys-navbar")) customElements.define("ys-navbar", YsNavbar);
</script>

<style>
	.navbar {
		position: sticky;
		top: 0;
		z-index: 50;
		display: block;
		border-bottom: 1px solid transparent;
		background: transparent;
		transition:
			background-color var(--motion-duration-base) var(--motion-ease-in-out-quad),
			border-color var(--motion-duration-base) var(--motion-ease-in-out-quad),
			backdrop-filter var(--motion-duration-base) var(--motion-ease-in-out-quad);
		view-transition-name: ys-navbar;
	}

	.navbar[data-condensed] {
		border-bottom-color: var(--color-border-subtle);
		background: var(--color-bg-translucent);
		backdrop-filter: blur(18px);
	}

	.navbar__inner,
	.navbar__desktop,
	.navbar__links,
	.navbar__actions,
	.navbar__brand,
	.mobile-nav__top,
	.mobile-nav__controls,
	.mobile-nav__links a {
		display: flex;
		align-items: center;
	}

	.navbar__inner {
		justify-content: space-between;
		gap: var(--space-4);
		min-height: 4.25rem;
	}

	.navbar__brand {
		flex: none;
		border-radius: var(--radius-6);
		font-weight: var(--font-weight-semibold);
		line-height: var(--line-height-ui);
	}

	.navbar__name {
		font-size: var(--font-size-16);
		letter-spacing: 0.08em;
	}

	.navbar__desktop {
		justify-content: flex-end;
		gap: var(--space-3);
	}

	.navbar__links {
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: var(--space-1);
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.navbar__links-wrap {
		position: relative;
		display: flex;
	}

	.navbar__link {
		position: relative;
		display: inline-flex;
		align-items: center;
		min-height: 2rem;
		border-radius: var(--radius-6);
		color: var(--color-text-muted);
		font-size: var(--font-size-14);
		font-weight: var(--font-weight-medium);
		padding-inline: var(--space-3);
		transition:
			background-color var(--motion-duration-fast) var(--motion-ease-standard),
			color var(--motion-duration-fast) var(--motion-ease-standard);
	}

	.navbar__indicator {
		position: absolute;
		bottom: -1px;
		left: 0;
		width: var(--indicator-width, 0);
		height: 1px;
		transform: translateX(var(--indicator-x, 0));
		transform-origin: left;
		background: var(--color-accent);
		opacity: 0;
		pointer-events: none;
		transition:
			width var(--motion-duration-base) var(--motion-ease-out-quart),
			transform var(--motion-duration-base) var(--motion-ease-out-quart);
	}

	.navbar__link:hover,
	.navbar__link[aria-current="page"] {
		background: var(--color-surface);
		color: var(--color-text-primary);
	}

	.navbar__locale,
	.mobile-nav__locale,
	.navbar__client-area,
	.mobile-nav__client-area {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.5rem;
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-6);
		color: var(--color-text-secondary);
		font-family: var(--font-mono);
		font-size: var(--font-size-12);
		font-weight: var(--font-weight-medium);
		padding-inline: var(--space-3);
	}

	.navbar__locale:hover,
	.mobile-nav__locale:hover,
	.navbar__client-area:hover,
	.mobile-nav__client-area:hover {
		border-color: var(--color-border-strong);
		color: var(--color-text-primary);
	}

	.navbar__toggle {
		display: none;
		gap: var(--space-3);
		min-height: 2.5rem;
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-6);
		background: var(--color-surface);
		color: var(--color-text-primary);
		font-size: var(--font-size-14);
		padding-inline: var(--space-3);
	}

	.navbar__compact {
		display: none;
		align-items: center;
		gap: var(--space-2);
	}

	.navbar__toggle-icon {
		display: grid;
		gap: 0.25rem;
		width: 1rem;
	}

	.navbar__toggle-icon i {
		display: block;
		height: 1px;
		background: currentColor;
	}

	.mobile-nav[hidden] {
		display: none;
	}

	.mobile-nav {
		position: fixed;
		inset: 0;
		z-index: 60;
		display: grid;
		grid-template-columns: minmax(2rem, 1fr) minmax(17rem, 26rem);
	}

	.mobile-nav__backdrop {
		border: 0;
		background: rgb(0 0 0 / 0.62);
		backdrop-filter: blur(4px);
	}

	.mobile-nav__panel {
		display: flex;
		flex-direction: column;
		gap: var(--space-8);
		min-height: 100dvh;
		border-left: 1px solid var(--color-border-subtle);
		background: var(--color-bg-elevated);
		padding: var(--space-5);
	}

	.mobile-nav__top,
	.mobile-nav__links a {
		justify-content: space-between;
	}

	.mobile-nav__controls {
		align-items: flex-start;
		gap: var(--space-2);
	}

	.mobile-nav__locale {
		width: fit-content;
	}

	.mobile-nav__client-area {
		width: 100%;
	}

	.mobile-nav__close {
		min-height: 2.5rem;
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-6);
		background: var(--color-surface);
		color: var(--color-text-primary);
		font-size: var(--font-size-14);
		padding-inline: var(--space-3);
	}

	.mobile-nav__links {
		display: grid;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.mobile-nav__links a {
		min-height: 3.5rem;
		border-bottom: 1px solid var(--color-border-subtle);
		font-size: var(--font-size-18);
	}

	.mobile-nav__links a[aria-current="page"] {
		color: var(--color-accent-strong);
	}

	@media (max-width: 859px) {
		html[data-menu-ready="true"] .navbar__desktop {
			display: none;
		}

		html[data-menu-ready="true"] .navbar__compact,
		html[data-menu-ready="true"] .navbar__toggle {
			display: flex;
		}

		.navbar__desktop {
			flex-wrap: wrap;
		}

		.navbar__desktop :global(.button) {
			display: none;
		}
	}

</style>

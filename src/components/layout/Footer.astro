---
import { navigation } from "../../data/site";
import Container from "./Container.astro";

const currentYear = new Date().getFullYear();
---

<footer class="footer">
	<Container size="xl">
		<div class="footer__top">
			<div class="footer__identity">
				<p class="footer__brand">YSWORKS</p>
				<p class="footer__descriptor">
					Ingeniería tecnológica para sistemas claros, seguros y mantenibles.
				</p>
			</div>
			<nav class="footer__nav" aria-label="Navegación del pie">
				{navigation.map((link) => <a href={link.href}>{link.label}</a>)}
				<a href="/privacy">Privacidad</a>
			</nav>
		</div>
		<div class="footer__bottom">
			<p>Quiet Engineering. Complejidad invisible, simplicidad visible.</p>
			<p>&copy; {currentYear} YSWORKS</p>
		</div>
	</Container>
</footer>

<style>
	.footer {
		border-top: 1px solid var(--color-border-subtle);
		background: var(--color-bg-translucent);
	}

	.footer__top {
		display: grid;
		gap: var(--space-8);
		padding-block: var(--space-12);
	}

	.footer__identity {
		display: grid;
		gap: var(--space-3);
	}

	.footer__brand {
		color: var(--color-text-primary);
		font-size: var(--font-size-14);
		font-weight: var(--font-weight-semibold);
		letter-spacing: 0.04em;
	}

	.footer__descriptor {
		max-width: 27rem;
	}

	.footer__nav {
		display: flex;
		flex-wrap: wrap;
		align-content: start;
		gap: var(--space-3) var(--space-6);
	}

	.footer__nav a {
		border-radius: var(--radius-4);
		color: var(--color-text-muted);
		font-size: var(--font-size-14);
		font-weight: var(--font-weight-medium);
		transition: color var(--motion-duration-fast) var(--motion-ease-standard);
	}

	.footer__nav a:hover {
		color: var(--color-text-primary);
	}

	.footer__bottom {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
		gap: var(--space-3) var(--space-8);
		border-top: 1px solid var(--color-border-subtle);
		padding-block: var(--space-5);
	}

	.footer__bottom p {
		color: var(--color-text-muted);
		font-size: var(--font-size-12);
	}

	@media (min-width: 768px) {
		.footer__top {
			grid-template-columns: 1fr auto;
			padding-block: var(--space-16);
		}
	}
</style>

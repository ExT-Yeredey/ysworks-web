---
import Card from "../ui/Card.astro";
import MonoEyebrow from "../typography/MonoEyebrow.astro";
import Paragraph from "../typography/Paragraph.astro";

interface Props {
	title: string;
	description: string;
	eyebrow?: string;
	href?: string;
	linkLabel?: string;
	headingLevel?: "h2" | "h3" | "h4";
}

const {
	title,
	description,
	eyebrow,
	href,
	linkLabel = "Learn more",
	headingLevel = "h3",
} = Astro.props;
const Heading = headingLevel;
---

<Card class="service-card" interactive={Boolean(href)}>
	<div class="service-card__icon" aria-hidden="true"><slot name="icon" /></div>
	<div class="service-card__content">
		{eyebrow && <MonoEyebrow>{eyebrow}</MonoEyebrow>}
		<Heading>{href ? <a href={href}>{title}</a> : title}</Heading>
		<Paragraph measure="none">{description}</Paragraph>
	</div>
	{href && <span class="service-card__action" aria-hidden="true">{linkLabel} →</span>}
</Card>

<style>
	:global(.card.service-card) {
		display: grid;
		align-content: start;
		gap: var(--space-6);
		height: 100%;
	}

	.service-card__icon {
		display: grid;
		place-items: center;
		width: 2.5rem;
		height: 2.5rem;
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-6);
		background: var(--color-bg-elevated);
		color: var(--color-accent-strong);
	}

	.service-card__icon:empty {
		display: none;
	}

	.service-card__content {
		display: grid;
		gap: var(--space-3);
	}

	.service-card :is(h2, h3, h4) {
		font-size: var(--font-size-24);
	}

	.service-card :is(h2, h3, h4) a {
		border-radius: var(--radius-4);
	}

	.service-card__action {
		align-self: end;
		color: var(--color-accent-strong);
		font-size: var(--font-size-14);
		font-weight: var(--font-weight-medium);
	}
</style>

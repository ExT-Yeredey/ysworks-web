---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"dialog"> {
	id: string;
	title: string;
	description?: string;
	size?: "sm" | "md" | "lg";
	closeLabel?: string;
}

const {
	id,
	title,
	description,
	size = "md",
	closeLabel = "Close",
	class: className,
	...attrs
} = Astro.props;
const titleId = `${id}-title`;
const descriptionId = description ? `${id}-description` : undefined;
const classes = ["modal", `modal--${size}`, className]
	.filter(Boolean)
	.join(" ");
---

<ys-modal data-modal-id={id}>
	<dialog
		class={classes}
		id={id}
		aria-labelledby={titleId}
		aria-describedby={descriptionId}
		{...attrs}
	>
		<div class="modal__surface">
			<header class="modal__header">
				<div class="modal__heading">
					<h2 id={titleId}>{title}</h2>
					{description && <p id={descriptionId}>{description}</p>}
				</div>
				<button class="modal__close" type="button" aria-label={closeLabel} data-modal-close>
					<svg aria-hidden="true" viewBox="0 0 16 16" width="16" height="16">
						<path d="m3 3 10 10M13 3 3 13" fill="none" stroke="currentColor" stroke-linecap="round"></path>
					</svg>
				</button>
			</header>
			<div class="modal__content"><slot /></div>
			{
				Astro.slots.has("footer") && (
					<footer class="modal__footer"><slot name="footer" /></footer>
				)
			}
		</div>
	</dialog>
</ys-modal>

<script>
	import { animate } from "animejs";

	class YsModal extends HTMLElement {
		connectedCallback() {
			const dialog = this.querySelector<HTMLDialogElement>("dialog");
			const surface = dialog?.querySelector<HTMLElement>(".modal__surface");
			const id = this.dataset.modalId;
			if (!dialog || !surface || !id) return;
			let previousFocus: HTMLElement | null = null;
			let closing = false;
			const reducedMotion = () =>
				window.matchMedia("(prefers-reduced-motion: reduce)").matches;

			const finishClose = () => {
				dialog.close();
				closing = false;
				dialog.removeAttribute("style");
				surface.removeAttribute("style");
				previousFocus?.focus();
			};

			const close = () => {
				if (!dialog.open || closing) return;
				closing = true;
				if (reducedMotion()) {
					finishClose();
					return;
				}
				animate(dialog, { opacity: 0, duration: 140, ease: "in(2)" });
				animate(surface, {
					opacity: 0,
					y: 8,
					scale: 0.985,
					duration: 170,
					ease: "in(3)",
					onComplete: finishClose,
				});
			};

			const open = () => {
				if (dialog.open) return;
				previousFocus = document.activeElement as HTMLElement;
				dialog.showModal();
				if (!reducedMotion()) {
					animate(dialog, { opacity: [0, 1], duration: 180, ease: "out(2)" });
					animate(surface, {
						opacity: [0, 1],
						y: [10, 0],
						scale: [0.985, 1],
						duration: 220,
						ease: "out(4)",
					});
				}
			};

			document.addEventListener("click", (event) => {
				const target = event.target;
				if (!(target instanceof Element)) return;
				const trigger = target.closest<HTMLElement>("[data-modal-open]");
				if (trigger?.dataset.modalOpen === id) open();
			});
			for (const control of dialog.querySelectorAll<HTMLElement>("[data-modal-close]")) {
				control.addEventListener("click", close);
			}
			dialog.addEventListener("cancel", (event) => {
				event.preventDefault();
				close();
			});
			dialog.addEventListener("click", (event) => {
				if (event.target === dialog) close();
			});
		}
	}

	if (!customElements.get("ys-modal")) customElements.define("ys-modal", YsModal);
</script>

<style>
	ys-modal {
		display: contents;
	}

	.modal {
		width: min(calc(100% - (var(--space-4) * 2)), var(--modal-width));
		max-height: min(48rem, calc(100dvh - (var(--space-4) * 2)));
		margin: auto;
		padding: 0;
		border: 0;
		background: transparent;
		color: var(--color-text-primary);
		overflow: visible;
	}

	.modal--sm {
		--modal-width: 28rem;
	}

	.modal--md {
		--modal-width: 40rem;
	}

	.modal--lg {
		--modal-width: 56rem;
	}

	.modal::backdrop {
		background: rgb(0 0 0 / 0.68);
		backdrop-filter: blur(4px);
	}

	.modal__surface {
		display: grid;
		max-height: inherit;
		overflow: hidden;
		border: 1px solid var(--color-border-strong);
		border-radius: var(--radius-12);
		background: var(--color-bg-elevated);
		box-shadow: var(--shadow-overlay);
	}

	.modal__header,
	.modal__footer {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: var(--space-6);
		padding: var(--space-5);
	}

	.modal__header {
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.modal__heading {
		display: grid;
		gap: var(--space-2);
	}

	.modal__heading h2 {
		font-size: var(--font-size-24);
	}

	.modal__heading p {
		font-size: var(--font-size-14);
	}

	.modal__close {
		display: inline-grid;
		place-items: center;
		flex: none;
		width: 2.5rem;
		height: 2.5rem;
		border: 1px solid var(--color-border-subtle);
		border-radius: var(--radius-6);
		background: var(--color-surface);
		color: var(--color-text-primary);
		cursor: pointer;
	}

	.modal__content {
		overflow-y: auto;
		padding: var(--space-5);
	}

	.modal__footer {
		justify-content: flex-end;
		border-top: 1px solid var(--color-border-subtle);
	}

	@media (min-width: 640px) {
		.modal__header,
		.modal__content,
		.modal__footer {
			padding: var(--space-6);
		}
	}
</style>

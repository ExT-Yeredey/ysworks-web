---
import ProcessCard from "../cards/ProcessCard.astro";
import MonoEyebrow from "../typography/MonoEyebrow.astro";
import Paragraph from "../typography/Paragraph.astro";
import SectionTitle from "../typography/SectionTitle.astro";

export interface ProcessStep {
	step: string;
	title: string;
	description: string;
}

interface Props {
	id?: string;
	eyebrow?: string;
	title: string;
	description?: string;
	steps: ProcessStep[];
}

const { id = "process", eyebrow, title, description, steps } = Astro.props;
const headingId = `${id}-title`;
---

<ys-process-motion>
<section class="process" id={id} aria-labelledby={headingId}>
	<header class="process__header">
		{eyebrow && <MonoEyebrow>{eyebrow}</MonoEyebrow>}
		<SectionTitle id={headingId}>{title}</SectionTitle>
		{description && <Paragraph size="lg">{description}</Paragraph>}
	</header>

	<div class="process__sequence">
		<span class="process__connector" aria-hidden="true" data-process-connector></span>
	<ol class="process__steps">
		{
			steps.map((item) => (
				<li data-process-step>
					<ProcessCard
						step={item.step}
						title={item.title}
						description={item.description}
						headingLevel="h3"
					/>
				</li>
			))
		}
	</ol>
	</div>
</section>
</ys-process-motion>

<script>
	import { animate, stagger } from "animejs";
	import {
		isMobileMotion,
		motion,
		onReducedMotionChange,
		observeOnce,
		prefersReducedMotion,
		runOncePerSession,
	} from "../../lib/motion";

	class YsProcessMotion extends HTMLElement {
		private stopObserving?: () => void;
		private stopReducedMotion?: () => void;
		private animations: Array<{ cancel: () => unknown }> = [];

		connectedCallback() {
		const process = this.querySelector<HTMLElement>(".process");
		const connector = this.querySelector<HTMLElement>("[data-process-connector]");
		const steps = this.querySelectorAll<HTMLElement>("[data-process-step]");
		if (!process || !connector || steps.length === 0) return;
		const finalIndexes = new Map<HTMLElement, string>();
		const finishReadable = () => {
			for (const animation of this.animations) animation.cancel();
			this.animations = [];
			connector.removeAttribute("style");
			for (const step of steps) {
				step.removeAttribute("style");
				const index = step.querySelector<HTMLElement>(".mono-eyebrow");
				const finalValue = index && finalIndexes.get(index);
				if (index && finalValue) index.textContent = finalValue;
			}
		};
		this.stopObserving = observeOnce(process, () => {
			runOncePerSession("ysworks:motion:process:v1", () => {
				if (prefersReducedMotion()) return;
				const vertical = window.matchMedia(
					`(max-width: ${motion.breakpoint.processVerticalMax}px)`,
				).matches;
				const stepDelay = isMobileMotion()
					? motion.choreography.processStepDelayMobile
					: motion.choreography.processStepDelayDesktop;
				this.animations.push(animate(connector, {
					scaleY: vertical ? [0, 1] : 1,
					scaleX: vertical ? 1 : [0, 1],
					duration: vertical ? motion.duration.overtureMax : motion.duration.overtureMin,
					ease: motion.ease.inOutQuad,
				}));
				this.animations.push(animate(steps, {
					opacity: [0.72, 1],
					y: [motion.travel.sm, 0],
					delay: stagger(stepDelay, { start: motion.choreography.processStepStart }),
					duration: motion.duration.base,
					ease: motion.ease.outExpo,
				}));
				for (const [stepIndex, step] of Array.from(steps).entries()) {
					const index = step.querySelector<HTMLElement>(".mono-eyebrow");
					const finalValue = index?.textContent?.trim();
					if (!index || !finalValue) continue;
					finalIndexes.set(index, finalValue);
					const counter = { value: 0 };
					index.textContent = "00";
					this.animations.push(animate(counter, {
						value: Number(finalValue),
						round: 1,
						delay: motion.choreography.processStepStart + stepDelay * stepIndex,
						duration: motion.duration.base,
						ease: motion.ease.outQuart,
						onUpdate: () => { index.textContent = String(counter.value).padStart(2, "0"); },
						onComplete: () => { index.textContent = finalValue; },
					}));
				}
			});
		});
		this.stopReducedMotion = onReducedMotionChange((reduced) => {
			if (reduced) finishReadable();
		});
		}

		disconnectedCallback() {
			this.stopObserving?.();
			this.stopReducedMotion?.();
			for (const animation of this.animations) animation.cancel();
		}
	}

	if (!customElements.get("ys-process-motion")) {
		customElements.define("ys-process-motion", YsProcessMotion);
	}
</script>

<style>
	.process {
		display: grid;
		gap: var(--space-12);
	}

	.process__header {
		display: grid;
		gap: var(--space-4);
		max-width: 48rem;
	}

	ys-process-motion,
	.process__sequence {
		display: block;
	}

	.process__sequence {
		position: relative;
	}

	.process__steps {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: var(--space-4);
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.process__connector {
		position: absolute;
		top: 0.8rem;
		right: 12.5%;
		left: 12.5%;
		height: 1.5px;
		transform-origin: left;
		background: var(--color-accent);
		opacity: 0.58;
	}

	.process__steps > li {
		position: relative;
		z-index: 1;
		min-width: 0;
	}

	.process__steps > li:last-child :global(.card) {
		border-color: var(--color-accent-border);
		background:
			linear-gradient(145deg, var(--color-accent-soft), transparent 70%),
			var(--color-surface);
	}

	@media (max-width: 64rem) {
		.process__steps {
			grid-template-columns: 1fr;
			gap: var(--space-5);
		}

		.process__connector {
			top: var(--space-4);
			bottom: var(--space-4);
			left: 1.05rem;
			width: 1.5px;
			height: auto;
			transform-origin: top;
		}

		.process__steps > li {
			padding-left: var(--space-8);
		}
	}

	@media (min-width: 64rem) {
		.process__header {
			grid-template-columns: minmax(0, 1.1fr) minmax(20rem, 0.9fr);
			column-gap: var(--space-16);
			max-width: none;
		}

		.process__header :global(.mono-eyebrow) {
			grid-column: 1 / -1;
		}

		.process__header :global(.paragraph) {
			align-self: end;
		}
	}

	@media (max-width: 36rem) {
		.process {
			gap: var(--space-8);
		}

		.process__steps {
			grid-template-columns: 1fr;
		}
	}
</style>

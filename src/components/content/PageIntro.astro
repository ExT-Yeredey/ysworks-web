---
import Badge from "../ui/Badge.astro";
import Container from "../layout/Container.astro";

interface Props {
	eyebrow: string;
	title: string;
	description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="page-intro" data-reveal>
	<Container size="lg">
		<div class="page-intro__content">
			<Badge tone="accent">{eyebrow}</Badge>
			<h1>{title}</h1>
			<p>{description}</p>
		</div>
	</Container>
</header>

<style>
	.page-intro {
		padding-block: var(--space-24) var(--space-16);
	}

	.page-intro__content {
		display: grid;
		gap: var(--space-5);
		max-width: 54rem;
	}

	h1 {
		font-size: clamp(var(--font-size-40), 7vw, var(--font-size-72));
		line-height: var(--line-height-tight);
		letter-spacing: -0.04em;
		text-wrap: balance;
	}

	p {
		max-width: 46rem;
		font-size: clamp(var(--font-size-18), 2.5vw, var(--font-size-22));
		text-wrap: pretty;
	}

	@media (min-width: 768px) {
		.page-intro {
			padding-block: var(--space-32) var(--space-24);
		}
	}
</style>

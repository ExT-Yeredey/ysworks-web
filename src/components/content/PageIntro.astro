---
import Badge from "../ui/Badge.astro";
import Container from "../layout/Container.astro";

interface Props {
	eyebrow: string;
	title: string;
	description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<header class="page-intro">
	<Container size="xl">
		<div class="page-intro__content">
			<Badge tone="accent">{eyebrow}</Badge>
			<h1>{title}</h1>
			<p>{description}</p>
		</div>
	</Container>
</header>

<style>
	.page-intro {
		position: relative;
		border-bottom: 1px solid var(--color-border-subtle);
		padding-block: var(--space-24) var(--space-16);
		background: linear-gradient(180deg, var(--color-accent-soft), transparent 68%);
	}

	.page-intro__content {
		display: grid;
		gap: var(--space-5);
		max-width: 54rem;
	}

	h1 {
		font-size: clamp(var(--font-size-40), 7vw, var(--font-size-72));
		line-height: var(--line-height-tight);
		letter-spacing: -0.04em;
		text-wrap: balance;
	}

	p {
		max-width: 46rem;
		font-size: clamp(var(--font-size-18), 2.5vw, var(--font-size-22));
		text-wrap: pretty;
	}

	@media (min-width: 768px) {
		.page-intro {
			padding-block: var(--space-32) var(--space-24);
		}
	}

	@media (min-width: 64rem) {
		.page-intro__content {
			grid-template-columns: minmax(0, 1.15fr) minmax(20rem, 0.85fr);
			column-gap: var(--space-16);
			max-width: none;
		}

		.page-intro__content :global(.badge) {
			grid-column: 1 / -1;
		}

		.page-intro__content p {
			align-self: end;
			padding-bottom: var(--space-2);
		}
	}
</style>
